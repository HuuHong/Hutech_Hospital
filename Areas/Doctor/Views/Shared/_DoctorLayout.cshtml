<!DOCTYPE html>
<html lang="vi">
<head>
    <link rel="icon" type="image/png" href="~/uploads/doctors/logo-hutech.png" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Doctor Portal</title>
    
    <!-- Bootstrap 5, FontAwesome, Google Fonts -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/hospital-ui.css" />
    <!-- Doctor Layout Specific CSS -->
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; }
        .doctor-sidebar {
            width: 280px; min-height: 100vh;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-right: 1px solid rgba(0,0,0,0.05);
            position: fixed; top: 0; left: 0; padding-top: 20px; z-index: 1000;
        }
        .main-content {
            margin-left: 280px; padding: 30px; min-height: 100vh;
        }
        .doctor-nav-link {
            padding: 15px 20px; border-radius: 12px; margin: 0 15px 10px 15px;
            color: #4b5563; font-weight: 500; transition: all 0.3s ease; display: block; text-decoration: none;
        }
        .doctor-nav-link:hover, .doctor-nav-link.active {
            background-color: var(--medical-primary); color: white; transform: translateY(-2px);
        }
        .top-header {
            background-color: white; padding: 15px 30px; border-radius: 16px; align-items: center; justify-content: space-between;
        }
    </style>
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <div class="doctor-sidebar shadow-sm">
            <div class="text-center mb-4 px-3">
                <i class="fa-solid fa-stethoscope text-primary fs-1 mb-2"></i>
                <h4 class="fw-bold text-dark m-0">Doctor Portal</h4>
                <p class="text-muted small">Hospital System</p>
            </div>
            
            <nav class="nav flex-column mt-4">
                <a href="/Doctor" class="doctor-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="fa-solid fa-house-chimney-medical me-3 w-20px text-center"></i>Tổng Quan Tình Hình
                </a>
                <a href="/Doctor/Schedule" class="doctor-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Schedule" ? "active" : "")">
                    <i class="fa-regular fa-calendar-days me-3 w-20px text-center"></i>Phân Ca Trực
                </a>
                <a href="/Doctor/Appointment/Today" class="doctor-nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Today" ? "active" : "")">
                    <i class="fa-solid fa-sun me-3 w-20px text-center text-warning"></i>Phiếu Khám Hôm Nay
                </a>
                <a href="/Doctor/Appointment" class="doctor-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Appointment" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                    <i class="fa-solid fa-list-check me-3 w-20px text-center"></i>Tất Cả Lịch Hẹn
                </a>
                <a href="/" class="doctor-nav-link text-info mt-3" target="_blank">
                    <i class="fa-solid fa-globe me-3 w-20px text-center"></i>Trang Chủ BV HUTECH
                </a>
            </nav>
        </div>
        
        <!-- Main Content Area -->
        <div class="main-content flex-grow-1">
            <div class="top-header shadow-sm mb-4 d-flex">
                <h5 class="fw-bold m-0 text-dark">Xin chào, BS. @User.Identity?.Name</h5>
                <div>
                    <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill me-3"><i class="fa-solid fa-circle text-success me-1" style="font-size:8px;"></i> Đang trực tuyến</span>
                    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3"><i class="fa-solid fa-power-off me-2"></i>Đăng xuất</button>
                    </form>
                </div>
            </div>
            
            <!-- Render Body -->
            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
