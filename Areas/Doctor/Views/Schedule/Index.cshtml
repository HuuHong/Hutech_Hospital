@model IEnumerable<HUTECH_Hospital.Models.DoctorSchedule>
@{
    ViewData["Title"] = "Lịch Trực Của Tôi";
    Layout = "~/Areas/Doctor/Views/Shared/_DoctorLayout.cshtml";
}

<div class="row mb-4">
    <div class="col-12">
        <h2 class="fw-bold text-dark"><i class="fa-solid fa-calendar-days text-primary me-3"></i>Lịch Giao Ban Cá Nhân</h2>
        <p class="text-muted">Xem khung giờ phần bổ khám theo chỉ định quản lý.</p>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light text-muted small text-uppercase">
                            <tr>
                                <th class="ps-4">Ngày làm việc</th>
                                <th>Thời gian chốt ca</th>
                                <th>Phòng Cấp Cứu/Khám</th>
                                <th>Tải lượng (Bệnh Nhân)</th>
                                <th>Trạng Thái</th>
                                <th>Ghi chú</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold fs-5 text-dark py-3">
                                        @item.WorkDate.ToString("dd/MM/yyyy")
                                        @if(item.WorkDate.Date == DateTime.Now.Date)
                                        {
                                            <span class="badge bg-danger ms-2" style="font-size:0.7rem;">HÔM NAY</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="bg-light d-inline-block px-3 py-2 rounded-3 text-primary fw-bold shadow-sm">
                                            @item.StartTime.ToString(@"hh\:mm") - @item.EndTime.ToString(@"hh\:mm")
                                        </div>
                                    </td>
                                    <td class="fw-bold fs-5">
                                        @item.Room
                                    </td>
                                    <td>
                                        Tối đa: <span class="badge bg-secondary">@item.MaxPatients người</span>
                                    </td>
                                    <td>
                                        @if(item.IsAvailable)
                                        {
                                            <span class="badge bg-success-subtle text-success px-2 py-1 rounded-pill"><i class="fa-solid fa-check-circle me-1"></i>Sẵn sàng Book</span>
                                        }
                                        else 
                                        {
                                            <span class="badge bg-danger-subtle text-danger px-2 py-1 rounded-pill"><i class="fa-solid fa-ban me-1"></i>Đóng danh sách</span>
                                        }
                                    </td>
                                    <td class="fst-italic text-muted">
                                        @(item.Note ?? "---")
                                    </td>
                                </tr>
                            }

                            @if(!Model.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-5">
                                        <i class="fa-regular fa-face-smile fs-1 text-muted mb-3"></i>
                                        <h5 class="text-secondary fw-bold">Hiện bác sĩ chưa được xếp lịch trực.</h5>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
