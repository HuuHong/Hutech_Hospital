@model HUTECH_Hospital.Models.Appointment

@{
    ViewData["Title"] = "Chi tiết Ca Khám";
    Layout = "~/Areas/Doctor/Views/Shared/_DoctorLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold m-0"><i class="fa-solid fa-notes-medical me-2 text-primary"></i>Hồ sơ Bệnh nhân #@Model.PatientId</h3>
    <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill px-4"><i class="fa-solid fa-arrow-left me-2"></i>Trở về</a>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body text-center p-4">
                <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3 text-primary" style="width: 100px; height: 100px;">
                    <i class="fa-solid fa-user-injured fa-3x"></i>
                </div>
                <h5 class="fw-bold mb-1">@Model.Patient?.FullName</h5>
                <p class="text-muted small mb-3">Mã Bệnh nhân: #@Model.PatientId</p>
                <hr>
                <div class="text-start">
                    <p class="mb-2"><i class="fa-solid fa-phone me-2 text-muted"></i>@Model.Patient?.PhoneNumber</p>
                    <p class="mb-2"><i class="fa-solid fa-envelope me-2 text-muted"></i>@Model.Patient?.ApplicationUser?.Email</p>
                    <p class="mb-0"><i class="fa-solid fa-cake-candles me-2 text-muted"></i>@(Model.Patient?.DateOfBirth?.ToString("dd/MM/yyyy") ?? "Chưa cung cấp")</p>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-8 mb-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                    <h5 class="fw-bold text-primary m-0">Nội dung Cuộc sống Hẹn</h5>
                    @if(Model.Status == "Pending") { <span class="badge bg-warning text-dark px-3 py-2">Khách Mới</span> }
                    else if(Model.Status == "Confirmed") { <span class="badge bg-success px-3 py-2">Sẵn sàng khám</span> }
                    else if(Model.Status == "Completed") { <span class="badge bg-info text-dark px-3 py-2">Ca đã xong</span> }
                    else { <span class="badge bg-danger px-3 py-2">Đã báo hủy</span> }
                </div>

                <div class="row mb-4">
                    <div class="col-6">
                        <small class="text-muted text-uppercase fw-bold d-block mb-1">Ngày Bệnh nhân Yêu cầu</small>
                        <h5 class="text-dark fw-bold">@Model.AppointmentDate.ToString("dd MMMM, yyyy")</h5>
                    </div>
                    <div class="col-6">
                        <small class="text-muted text-uppercase fw-bold d-block mb-1">Khung Giờ</small>
                        <h5 class="text-primary fw-bold">@Model.AppointmentTime.ToString(@"hh\:mm")</h5>
                    </div>
                </div>

                <div class="bg-light p-4 rounded-4 mb-4 border-start border-4 border-primary">
                    <h6 class="text-muted fw-bold mb-2">Triệu chứng/Lý do khai báo:</h6>
                    <p class="fs-5 mb-0 text-dark">"@Model.Reason"</p>
                </div>

                @if (!string.IsNullOrEmpty(Model.CancelReason))
                {
                    <div class="alert alert-danger rounded-3">
                        <strong><i class="fa-solid fa-circle-xmark me-2"></i>Lý do từ chối hỗ trợ:</strong> @Model.CancelReason
                    </div>
                }
                
                @if (!string.IsNullOrEmpty(Model.Note))
                {
                    <div class="alert alert-info rounded-3">
                        <strong><i class="fa-solid fa-circle-info me-2"></i>Ghi chú từ bộ phận Điều phối:</strong> @Model.Note
                    </div>
                }
                
                <div class="text-end mt-5">
                    @if(Model.Status == "Confirmed")
                    {
                        <!-- Tính năng Khám bệnh Phase 4 -->
                        <button class="btn btn-primary rounded-pill px-5 py-2 fw-bold" onclick="alert('Tính năng Tạo Hồ sơ Bệnh Án và Kê Đơn Thuốc sẽ được phát triển ở Phase 4!');"><i class="fa-solid fa-stethoscope me-2"></i>Bắt Đầu Khám</button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
