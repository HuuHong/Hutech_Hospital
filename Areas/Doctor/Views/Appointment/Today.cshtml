@model IEnumerable<HUTECH_Hospital.Models.Appointment>

@{
    ViewData["Title"] = "Cuộc hẹn Hôm Nay";
    Layout = "~/Areas/Doctor/Views/Shared/_DoctorLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold m-0"><i class="fa-solid fa-sun me-2 text-warning"></i>Bệnh nhân Hôm Nay</h3>
    <span class="badge bg-primary fs-6 px-4 py-2 rounded-pill">@DateTime.Now.ToString("dd MMMM, yyyy")</span>
</div>

<div class="card border-0 shadow-sm rounded-4 border-top border-warning border-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Giờ nhận Bệnh</th>
                        <th>Họ tên Bệnh nhân</th>
                        <th>Chỉ định ban đầu</th>
                        <th>Trạng thái hồ sơ</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="text-muted"><i class="fa-regular fa-face-smile fa-3x mb-3 text-success"></i><br>Tuyệt vời! Bạn không có ca khám nào tồn đọng trong hôm nay.</div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold fs-5 text-primary">@item.AppointmentTime.ToString(@"hh\:mm")</td>
                                <td>
                                    <div class="fw-bold fs-6">@item.Patient?.FullName</div>
                                    <small class="text-muted">ĐT: @item.Patient?.PhoneNumber</small>
                                </td>
                                <td>
                                    <div class="bg-light p-2 rounded text-truncate" style="max-width: 250px;" title="@item.Reason">@item.Reason</div>
                                </td>
                                <td>
                                    @if(item.Status == "Pending") { <span class="badge bg-warning text-dark px-3 py-2">Khách mới (Chờ lễ tân duyệt)</span> }
                                    else if(item.Status == "Confirmed") { <span class="badge bg-success px-3 py-2">Sẵn sàng khám</span> }
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm px-3 rounded-pill">Xem CA</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
