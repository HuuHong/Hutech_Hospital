@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="fw-bold text-dark mb-4">Tổng quan hệ thống</h2>

<div class="row g-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted fw-bold mb-1">TỔNG TÀI KHOẢN</h6>
                    <h2 class="fw-bolder text-dark mb-0">@ViewBag.TotalUsers</h2>
                </div>
                <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-circle fs-4">
                    <i class="fa-solid fa-users"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted fw-bold mb-1">BỆNH NHÂN (PATIENT)</h6>
                    <h2 class="fw-bolder text-dark mb-0">@Model.TotalPatients</h2>
                </div>
                <div class="bg-info bg-opacity-10 text-info p-3 rounded-circle fs-4">
                    <i class="fa-solid fa-hospital-user"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted fw-bold mb-1">HỒ SƠ BÁC SĨ</h6>
                    <h2 class="fw-bolder text-dark mb-0">@Model.TotalDoctors</h2>
                </div>
                <div class="bg-success bg-opacity-10 text-success p-3 rounded-circle fs-4">
                    <i class="fa-solid fa-user-doctor"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted fw-bold mb-1">HỒ SƠ BỆNH ÁN</h6>
                    <h2 class="fw-bolder text-dark mb-0">@Model.TotalMedicalRecords</h2>
                </div>
                <div class="bg-danger bg-opacity-10 text-danger p-3 rounded-circle fs-4">
                    <i class="fa-solid fa-file-medical"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 mt-4">
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted fw-bold mb-1">CA KHÁM HÔM NAY</h6>
                    <h2 class="fw-bolder text-dark mb-0">@Model.TodayAppointments</h2>
                </div>
                <div class="bg-warning bg-opacity-10 text-warning p-3 rounded-circle fs-4">
                    <i class="fa-solid fa-calendar-day"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 mt-4">
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted fw-bold mb-1">PHẢN HỒI (CHƯA XỬ LÝ)</h6>
                    <h2 class="fw-bolder text-danger mb-0">@Model.UnresolvedFeedbacks / @Model.TotalFeedbacks</h2>
                </div>
                <div class="bg-secondary bg-opacity-10 text-secondary p-3 rounded-circle fs-4">
                    <i class="fa-solid fa-comments"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4 p-4 text-center">
            <div class="empty-state p-5 text-muted">
                <i class="fa-solid fa-chart-line fs-1 mb-3 text-light-gray"></i>
                <p>Nơi đây sẽ hiển thị Biểu đồ tương tác trong các Phase nâng cao.</p>
            </div>
        </div>
    </div>
</div>
