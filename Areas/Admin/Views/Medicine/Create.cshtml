@model HUTECH_Hospital.Models.Medicine
@{
    ViewData["Title"] = "Thêm mới Thuốc";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card border-0 shadow-sm page-card mx-auto" style="max-width: 600px;">
    <div class="card-body p-4">
        <h4 class="fw-bold mb-4">Thêm mới phần tử Y tế</h4>
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold">Tên thuốc <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Unit" class="form-label fw-bold">Đơn vị (Viên, Chai, Gói...) <span class="text-danger">*</span></label>
                <input asp-for="Unit" class="form-control" required />
            </div>
            <div class="mb-3">
                <label asp-for="Usage" class="form-label fw-bold">Cách dùng mặc định</label>
                <input asp-for="Usage" class="form-control" placeholder="Uống sau ăn" />
            </div>
            <div class="mb-4">
                <label asp-for="Description" class="form-label fw-bold">Mô tả thêm</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            
            <div class="d-flex justify-content-between">
                <a href="/Admin/Medicine/Index" class="btn btn-light border">Hủy bỏ</a>
                <button type="submit" class="btn btn-primary"><i class="fa-solid fa-save me-2"></i> Lưu dữ liệu</button>
            </div>
        </form>
    </div>
</div>
