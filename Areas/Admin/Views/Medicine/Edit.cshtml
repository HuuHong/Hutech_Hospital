@model HUTECH_Hospital.Models.Medicine
@{
    ViewData["Title"] = "Sửa thông tin y tế";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card border-0 shadow-sm page-card mx-auto" style="max-width: 600px;">
    <div class="card-body p-4">
        <h4 class="fw-bold mb-4">Cập nhật danh mục</h4>
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />
            
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold">Tên thuốc</label>
                <input asp-for="Name" class="form-control" required />
            </div>
            <div class="mb-3">
                <label asp-for="Unit" class="form-label fw-bold">Đơn vị</label>
                <input asp-for="Unit" class="form-control" required />
            </div>
            <div class="mb-3">
                <label asp-for="Usage" class="form-label fw-bold">Cách dùng mặc định</label>
                <input asp-for="Usage" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-bold">Mô tả thêm</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            
            <div class="mb-4 form-check form-switch">
                <input class="form-check-input" type="checkbox" asp-for="IsActive" id="statusSwitch">
                <label class="form-check-label fw-bold ms-2" for="statusSwitch">Đang lưu hành bình thường</label>
            </div>
            
            <div class="d-flex justify-content-between">
                <a href="/Admin/Medicine/Index" class="btn btn-light border">Hủy bỏ</a>
                <button type="submit" class="btn btn-warning"><i class="fa-solid fa-save me-2"></i> Cập nhật</button>
            </div>
        </form>
    </div>
</div>
