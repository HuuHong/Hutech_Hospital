@model HUTECH_Hospital.Models.Medicine
@{
    ViewData["Title"] = "Chi tiết Thuốc";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card border-0 shadow-sm page-card mx-auto" style="max-width: 600px;">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
            <h4 class="fw-bold m-0 text-primary">@Model.Name</h4>
            @if(Model.IsActive){ <span class="badge bg-success">Đang kinh doanh</span> }
            else{ <span class="badge bg-secondary">Ngừng sử dụng</span> }
        </div>
        <table class="table table-borderless">
            <tr>
                <td class="text-muted fw-bold" style="width: 150px;">Đơn vị:</td>
                <td>@Model.Unit</td>
            </tr>
            <tr>
                <td class="text-muted fw-bold">Cách dùng gợi ý:</td>
                <td>@Model.Usage</td>
            </tr>
            <tr>
                <td class="text-muted fw-bold">Mô tả chi tiết:</td>
                <td>@Model.Description</td>
            </tr>
            <tr>
                <td class="text-muted fw-bold">Ngày thêm:</td>
                <td>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
            </tr>
        </table>
        
        <div class="d-flex justify-content-between mt-4">
            <a href="/Admin/Medicine/Index" class="btn btn-light border">Bảng Danh Mục</a>
            <a href="/Admin/Medicine/Edit/@Model.Id" class="btn btn-primary"><i class="fa-solid fa-pen me-2"></i> Chỉnh sửa</a>
        </div>
    </div>
</div>
