@model HUTECH_Hospital.Models.Medicine
@{
    ViewData["Title"] = "Xóa Thuốc";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card border-0 shadow-sm page-card mx-auto" style="max-width: 600px;">
    <div class="card-body p-4 text-center">
        <i class="fa-solid fa-triangle-exclamation fa-4x text-danger mb-4"></i>
        <h4 class="fw-bold mb-3">Xóa Dữ liệu Thuốc</h4>
        <p class="text-muted">Bộ phận Y tế có chắc chắn muốn xóa bản ghi của:<br>
            <strong class="text-danger fs-4">@Model.Name</strong>
        </p>

        <div class="alert alert-warning text-start small">
            <i class="fa-solid fa-info-circle me-2"></i> Hệ thống sẽ kiểm tra. Nếu loại thuốc này đã được sử dụng trong các Đơn thuốc của bệnh nhân trước đó, hệ thống sẽ chỉ chuyển <strong>Trạng thái về "Ngừng kinh doanh"</strong> thay vì xóa vĩnh viễn để bảo vệ tính toàn vẹn dữ liệu Y khoa.
        </div>
        
        <form asp-action="Delete" method="post" class="mt-4">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex justify-content-center gap-3">
                <a href="/Admin/Medicine/Index" class="btn btn-light border">Hủy bỏ</a>
                <button type="submit" class="btn btn-danger"><i class="fa-solid fa-trash me-2"></i> Xác nhận Xóa</button>
            </div>
        </form>
    </div>
</div>
