@model HUTECH_Hospital.Models.DoctorSchedule
@{
    ViewData["Title"] = "Hủy Ca Trực";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" class="btn btn-light rounded-circle shadow-sm" style="width:40px;height:40px;padding:8px;"><i class="fa-solid fa-arrow-left"></i></a>
    <h2 class="fw-bold m-0 text-danger">Hủy Bỏ / Xóa Ca Trực Bác Sĩ</h2>
</div>

<div class="row">
    <div class="col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 border-start border-danger border-4">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <div class="bg-danger rounded-circle mx-auto d-flex align-items-center justify-content-center text-white mb-3" style="width:80px;height:80px;font-size:2rem;">
                        <i class="fa-solid fa-calendar-xmark"></i>
                    </div>
                    <h4 class="fw-bold text-dark">Xác nhận bãi bỏ</h4>
                    <p class="text-muted">Ca trực của <b>BS. @Model.Doctor.FullName</b> vào ngày <b>@Model.WorkDate.ToString("dd/MM/yyyy")</b> sẽ bị xoá sổ khỏi bảng tính.</p>
                </div>
                
                <div class="bg-danger bg-opacity-10 p-3 rounded-3 mb-4 text-center">
                    <span class="text-danger fw-bold"><i class="fa-solid fa-triangle-exclamation me-2"></i>Cảnh báo Data Base!</span>
                    <p class="small text-danger m-0 mt-1">Dữ liệu xóa 1 lần sẽ biến mất vĩnh viễn và không thể khôi phục bảng kê này.</p>
                </div>

                <form asp-action="Delete" method="post" class="d-flex gap-2">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger flex-grow-1 rounded-pill fw-bold shadow-sm">Xóa vĩnh viễn Ca Trực</button>
                    <a asp-action="Index" class="btn btn-light flex-grow-1 rounded-pill fw-bold shadow-sm border">Từ chối, quay lại</a>
                </form>
            </div>
        </div>
    </div>
</div>
