@model HUTECH_Hospital.Models.DoctorSchedule
@{
    ViewData["Title"] = "Chi Tiết Lịch Trực";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4 gap-3">
    <div class="d-flex align-items-center gap-3">
        <a asp-action="Index" class="btn btn-light rounded-circle shadow-sm" style="width:40px;height:40px;padding:8px;"><i class="fa-solid fa-arrow-left"></i></a>
        <h2 class="fw-bold m-0 text-dark">Metadata Ca Lịch Trực Biên Sự</h2>
    </div>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning rounded-pill px-4 shadow-sm text-dark fw-bold"><i class="fa-solid fa-pen me-2"></i>Chỉnh sửa</a>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 text-center p-4 py-5 mb-4 border-top border-primary border-4 h-100">
            <h5 class="fw-bold text-muted mb-4 text-uppercase">Khung thời gian</h5>
            <div class="bg-primary bg-opacity-10 text-primary py-3 px-4 rounded-4 fw-bold mx-auto mb-4" style="font-size:2rem; width:fit-content;">
                @Model.StartTime.ToString(@"hh\:mm") <i class="fa-solid fa-arrow-right mx-2 text-muted" style="font-size:1.5rem"></i> @Model.EndTime.ToString(@"hh\:mm")
            </div>
            <h4 class="fw-bold">@Model.WorkDate.ToString("dd/MM/yyyy")</h4>
            <div class="mt-4 text-start bg-light p-3 rounded-3 mx-auto" style="max-width: 300px;">
                <p class="mb-2"><span class="text-muted">Phòng:</span> <span class="fw-bold float-end">@Model.Room</span></p>
                <p class="mb-0"><span class="text-muted">Tối đa B/N:</span> <span class="fw-bold float-end">@Model.MaxPatients khách</span></p>
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 p-4 py-5 mb-4 bg-primary text-white border-top border-dark border-4 h-100 position-relative overflow-hidden">
            <i class="fa-solid fa-user-doctor position-absolute" style="font-size: 10rem; opacity:0.1; bottom:-20px; right:-10px;"></i>
            
            <h5 class="fw-bold text-white-50 mb-4 text-uppercase">Bác Sĩ Tiếp Cận</h5>
            
            <div class="d-flex align-items-center mb-4">
                @if (!string.IsNullOrEmpty(Model.Doctor?.AvatarUrl))
                {
                    <img src="@Model.Doctor.AvatarUrl" class="rounded-circle border border-2 border-white me-3" width="80" height="80" style="object-fit:cover;" />
                }
                else
                {
                    <div class="bg-white rounded-circle d-flex align-items-center justify-content-center text-primary me-3" style="width:80px;height:80px;font-size:2rem;">
                        <i class="fa-solid fa-user-doctor"></i>
                    </div>
                }
                <div>
                    <h3 class="fw-bold mb-1">BS. @(Model.Doctor?.FullName ?? "N/A")</h3>
                    <p class="text-white-50 m-0">@(Model.Doctor?.Department?.Name ?? "Chưa phân khoa")</p>
                </div>
            </div>

            <div class="bg-white bg-opacity-10 p-3 rounded-3 border border-white border-opacity-25 mt-4 text-start">
                <span class="text-white fw-bold mb-1 d-block"><i class="fa-solid fa-square-check me-2 text-success"></i>Trạng thái Tương tác Hệ thống:</span>
                @if(Model.IsAvailable) {
                    <span class="badge bg-success float-end px-3 py-2 rounded-pill">Sẵn sàng nhận Book</span>
                } else {
                    <span class="badge bg-danger float-end px-3 py-2 rounded-pill">Đã khóa Đặt ca</span>
                }
            </div>
            
            @if(!string.IsNullOrEmpty(Model.Note)) {
                <div class="mt-3 p-3 bg-dark bg-opacity-25 rounded text-start fst-italic">
                    Ghi chú nội bộ: "@Model.Note"
                </div>
            }
        </div>
    </div>
</div>
