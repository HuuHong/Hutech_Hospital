@model IEnumerable<HUTECH_Hospital.Models.DoctorSchedule>
@{
    ViewData["Title"] = "Quản lý Lịch Làm Việc";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark">Lịch phân ca Bác Sĩ</h2>
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm"><i class="fa-solid fa-calendar-plus me-2"></i> Xếp Lịch Phân Ca mới</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0" role="alert">
        <i class="fa-solid fa-check me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">Ngày / Bác Sĩ</th>
                        <th>Khung Thời Gian</th>
                        <th>Phòng Trực</th>
                        <th>Giới hạn & Tình trạng</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="fw-bold text-dark fs-5 text-primary mb-1">
                                    <i class="fa-regular fa-calendar me-2"></i>@item.WorkDate.ToString("dd/MM/yyyy")
                                </div>
                                <div class="d-flex align-items-center mt-2">
                                    @if (!string.IsNullOrEmpty(item.Doctor?.AvatarUrl))
                                    {
                                        <img src="@item.Doctor.AvatarUrl" class="rounded-circle me-2 border" width="30" height="30" style="object-fit:cover;" />
                                    }
                                    <div class="small fw-bold text-secondary">BS. @(item.Doctor?.FullName ?? "N/A")</div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-primary px-3 py-2 fs-6 rounded-pill">
                                    <i class="fa-regular fa-clock me-1"></i>@item.StartTime.ToString(@"hh\:mm") - @item.EndTime.ToString(@"hh\:mm")
                                </span>
                            </td>
                            <td class="fw-bold text-info"><i class="fa-solid fa-door-open me-2"></i>@(item.Room ?? "---")</td>
                            <td>
                                <div class="mb-1"><small class="text-muted">Tối đa:</small> <span class="fw-bold">@item.MaxPatients</span> <small>khách</small></div>
                                @if (item.IsAvailable)
                                {
                                    <span class="badge bg-success-subtle text-success px-2 py-1 rounded-pill">Sẵn sàng nhận lịch</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger px-2 py-1 rounded-pill">Dừng / Khóa đăng ký</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light text-primary" title="Chi tiết"><i class="fa-solid fa-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light text-warning" title="Sửa lịch"><i class="fa-solid fa-pen"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-light text-danger" title="Bãi bỏ lịch"><i class="fa-solid fa-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if(!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fa-regular fa-calendar-xmark fs-1 mb-3 text-light-gray"></i>
                                <p>Hệ thống hiện chưa có bất kỳ sự kiện xếp lịch nào.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
