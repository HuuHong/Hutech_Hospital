@model IEnumerable<HUTECH_Hospital.Models.Notification>
@{
    ViewData["Title"] = "Quản lý Thông báo";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold m-0"><i class="fa-solid fa-bullhorn text-primary me-2"></i>Chiến dịch Thông báo</h2>
    <a href="/Admin/Notification/Create" class="btn btn-primary"><i class="fa-solid fa-paper-plane me-2"></i>Tạo Thông báo mới</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<div class="card border-0 shadow-sm page-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 15%">Đối tượng</th>
                        <th style="width: 30%">Tiêu đề</th>
                        <th style="width: 35%">Nội dung tóm tắt</th>
                        <th style="width: 20%">Ngày gửi</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if(item.PatientId == null) { <span class="badge bg-danger rounded-pill px-3">Tất cả BN (Global)</span> }
                                else { <span class="badge bg-info rounded-pill px-3">Cá nhân (#@item.PatientId)</span> }
                            </td>
                            <td class="fw-bold text-dark">@item.Title</td>
                            <td>@(item.Content.Length > 50 ? item.Content.Substring(0, 50) + "..." : item.Content)</td>
                            <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
