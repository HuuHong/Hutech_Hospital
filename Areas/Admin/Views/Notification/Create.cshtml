@model HUTECH_Hospital.Models.Notification
@{
    ViewData["Title"] = "Gửi thông báo";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card border-0 shadow-sm page-card mx-auto" style="max-width: 600px;">
    <div class="card-header bg-primary text-white border-bottom py-3">
        <h4 class="m-0 fw-bold"><i class="fa-solid fa-paper-plane me-2"></i>Trung tâm Soạn thảo Thông báo</h4>
    </div>
    <div class="card-body p-4 p-md-5">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-4 bg-light p-3 rounded-3 border">
                <label class="form-label fw-bold">Gửi đến Đối tượng (Phân khúc) <i class="fa-solid fa-users mx-1 text-primary"></i></label>
                <select asp-for="PatientId" asp-items="ViewBag.Patients" class="form-select border-primary" style="border-width: 2px;">
                    <option value="">-- [ Gửi cho Tất cả Bệnh nhân trong hệ thống (Broadcast) ] --</option>
                </select>
                <div class="form-text text-muted mt-2"><i class="fa-solid fa-info-circle me-1"></i> Để trống nếu muốn biến đây thành Thông báo Đại trà (Global Alert) cho mọi User trong Portal.</div>
            </div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-bold">Tiêu đề thông báo</label>
                <input asp-for="Title" class="form-control" placeholder="Ví dụ: Thay đổi lịch nghỉ Mùa Hè..." required />
            </div>

            <div class="mb-4">
                <label asp-for="Content" class="form-label fw-bold">Nội dung chi tiết</label>
                <textarea asp-for="Content" class="form-control" rows="5" placeholder="Soạn thảo thông điệp..." required></textarea>
            </div>

            <div class="d-flex justify-content-between">
                <a href="/Admin/Notification/Index" class="btn btn-light border px-4">Hủy</a>
                <button type="submit" class="btn btn-primary px-5 fw-bold"><i class="fa-solid fa-share-from-square me-2"></i> PUSH LÊN CLOUD</button>
            </div>
        </form>
    </div>
</div>
