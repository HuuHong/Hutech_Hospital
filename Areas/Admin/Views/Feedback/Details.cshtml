@model HUTECH_Hospital.Models.Feedback
@{
    ViewData["Title"] = "Chi tiết Phản hồi";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold m-0">Chi tiết Phản hồi #@Model.Id</h2>
        <span class="text-muted">Gửi bởi: <span class="fw-bold">@Model.Patient?.FullName</span> (@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm"))</span>
    </div>
    <a href="/Admin/Feedback/Index" class="btn btn-light border"><i class="fa-solid fa-arrow-left me-2"></i>Quay lại</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<div class="row">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm page-card mb-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-3">
                    <h5 class="fw-bold m-0">@Model.Title</h5>
                    <div class="text-warning fs-5">
                        @for(int i=0; i<Model.Rating; i++) { <i class="fa-solid fa-star"></i> }
                    </div>
                </div>
                <div class="bg-light p-4 rounded-3 text-dark fs-6 mb-4">
                    @Model.Content
                </div>

                <div class="reply-section mt-5 border-top pt-4">
                    <h5 class="fw-bold mb-3"><i class="fa-solid fa-reply text-success me-2"></i>Hệ thống trả lời</h5>
                    @if (string.IsNullOrEmpty(Model.Reply))
                    {
                        <form asp-action="Reply" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <div class="mb-3">
                                <textarea name="reply" class="form-control" rows="4" placeholder="Nhập câu trả lời chuyên môn..." required></textarea>
                            </div>
                            <button type="submit" class="btn btn-success"><i class="fa-solid fa-paper-plane me-2"></i> Gửi phản hồi người bệnh</button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-success bg-success bg-opacity-10 border-success">
                            <div class="small fw-bold text-success mb-1">Gửi lúc: @Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm")</div>
                            <div>@Model.Reply</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card border-0 shadow-sm page-card">
            <div class="card-body text-center p-4">
                <div class="status-circle mb-3">
                    @if(Model.IsResolved)
                    {
                        <i class="fa-solid fa-check-circle text-success fa-5x"></i>
                        <h4 class="mt-3 fw-bold text-success">Đã Đóng</h4>
                    }
                    else
                    {
                        <i class="fa-solid fa-circle-exclamation text-danger fa-5x"></i>
                        <h4 class="mt-3 fw-bold text-danger">Chưa Xử Lý</h4>
                        
                        <form asp-action="MarkResolved" method="post" class="mt-4">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-danger w-100"><i class="fa-solid fa-check me-2"></i> Đánh dấu tự động đóng</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
