<!DOCTYPE html>
<html lang="vi">
<head>
    <link rel="icon" type="image/png" href="~/uploads/doctors/logo-hutech.png" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Hospital</title>
    
    <!-- Bootstrap 5 & FontAwesome -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/hospital-ui.css" />
    
    <!-- Custom Admin Styles -->
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f3f4f6; }
        #sidebarMenu { min-height: 100vh; box-shadow: 4px 0 10px rgba(0,0,0,0.05); }
        .nav-link { border-radius: 10px; margin-bottom: 5px; color: rgba(255,255,255,0.8); transition: 0.3s; padding: 12px 20px;}
        .nav-link:hover, .nav-link.active { background-color: rgba(255,255,255,0.1) !important; color: white; transform: translateX(5px); }
        .admin-header { background: white; border-radius: 12px; padding: 15px 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.02); }
    </style>
</head>
<body>
    <div class="d-flex flex-nowrap">
        <!-- Sidebar -->
        <div class="d-flex flex-column flex-shrink-0 p-3 bg-dark text-white" style="width: 280px;" id="sidebarMenu">
            <a href="/Admin" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto text-white text-decoration-none px-3">
                <i class="fa-solid fa-hospital-symbol fs-2 text-primary me-3"></i>
                <span class="fs-4 fw-bold">Admin Panel</span>
            </a>
            <hr>
            <ul class="nav flex-column mb-auto">
                <li class="nav-item">
                    <a href="/Admin" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")">
                        <i class="fa-solid fa-chart-pie me-2"></i>Tổng Quan Admin
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/Admin/Department" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Department" ? "active" : "")">
                        <i class="fa-solid fa-hospital-user me-2"></i>Quản lý Chuyên khoa
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/Admin/Doctor" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Doctor" ? "active" : "")">
                        <i class="fa-solid fa-user-doctor me-2"></i>Vận hành Bác sĩ
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/Admin/DoctorSchedule" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "DoctorSchedule" ? "active" : "")">
                        <i class="fa-solid fa-calendar-alt me-2"></i>Phân ca lịch trực
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/Admin/Appointment" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Appointment" ? "active" : "")">
                        <i class="fa-solid fa-calendar-check me-2"></i>Quản lý Phiếu Khám
                    </a>
                </li>
                <!-- Phase 4 Additions -->
                <li class="nav-item border-top mt-2 pt-2 border-secondary">
                    <span class="ps-3 text-secondary small fw-bold text-uppercase">Nghiệp vụ Y khoa</span>
                </li>
                <li class="nav-item">
                    <a href="/Admin/MedicalRecord" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "MedicalRecord" ? "active" : "")">
                        <i class="fa-solid fa-file-medical me-2"></i>Kho Hồ sơ EHR
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/Admin/Medicine" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Medicine" ? "active" : "")">
                        <i class="fa-solid fa-pills me-2"></i>Danh mục Thuốc
                    </a>
                </li>
                <li class="nav-item border-top mt-2 pt-2 border-secondary">
                    <span class="ps-3 text-secondary small fw-bold text-uppercase">Truyền thông & LH</span>
                </li>
                <li class="nav-item">
                    <a href="/Admin/Notification" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Notification" ? "active" : "")">
                        <i class="fa-solid fa-bullhorn me-2"></i>Gửi Thông báo
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/Admin/Feedback" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Feedback" ? "active" : "")">
                        <i class="fa-solid fa-comments me-2"></i>Phản hồi & CSKH
                    </a>
                </li>
                <li class="nav-item mt-4">
                    <a href="/" class="nav-link text-info fw-bold" target="_blank">
                        <i class="fa-solid fa-globe me-2"></i>Xem Website Bệnh Viện
                    </a>
                </li>
            </ul>
            <hr>
            <div class="dropdown">
                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="w-100">
                    <button type="submit" class="btn btn-outline-light w-100 rounded-pill"><i class="fa-solid fa-sign-out-alt me-2"></i>Đăng Xuất</button>
                </form>
            </div>
        </div>
        
        <!-- Main Content -->
        <div class="flex-grow-1 p-4 bg-light overflow-auto" style="height: 100vh;">
            <div class="admin-header d-flex justify-content-between align-items-center mb-4">
                <h4 class="m-0 fw-bold text-dark">HUTECH HOSPITAL SYSTEM MANAGER</h4>
                <div class="d-flex align-items-center">
                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2 shadow-sm" style="width: 40px; height:40px;">
                        <i class="fa-solid fa-user-shield"></i>
                    </div>
                    <div>
                        <div class="fw-bold lh-1 text-dark">@User.Identity?.Name</div>
                        <small class="text-success"><i class="fa-solid fa-circle" style="font-size: 8px;"></i> Online</small>
                    </div>
                </div>
            </div>
            
            <main>
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
