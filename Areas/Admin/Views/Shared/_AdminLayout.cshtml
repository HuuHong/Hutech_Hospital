<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Căn hộ Quản trị</title>
    
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Admin Custom CSS -->
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-bg">
    <div class="d-flex" id="wrapper">
        <!-- Sidebar -->
        <div class="bg-dark text-white shadow-sm" id="sidebar-wrapper">
            <div class="sidebar-heading text-center py-4 border-bottom border-secondary">
                <i class="fa-solid fa-server text-info fs-3 mb-2"></i><br/>
                <span class="fw-bold">ADMIN WORKSPACE</span>
            </div>
            <div class="list-group list-group-flush my-3">
                <a href="/Admin/Dashboard" class="list-group-item list-group-item-action bg-transparent text-light fw-bold">
                    <i class="fa-solid fa-gauge-high me-2"></i> Dashboard
                </a>
                <a href="/Admin/User" class="list-group-item list-group-item-action bg-transparent text-light fw-bold">
                    <i class="fa-solid fa-users me-2"></i> Quản lý Người Dùng
                </a>
                <a href="/Admin/Doctor" class="list-group-item list-group-item-action bg-transparent text-light fw-bold">
                    <i class="fa-solid fa-user-doctor me-2"></i> Quản lý Bác Sĩ
                </a>
                <a href="/" class="list-group-item list-group-item-action bg-transparent text-info fw-bold mt-3">
                    <i class="fa-solid fa-globe me-2"></i> Xem Website Main
                </a>
            </div>
        </div>
        
        <!-- Page Content -->
        <div id="page-content-wrapper" class="w-100">
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm px-4 py-3">
                <div class="d-flex align-items-center w-100 justify-content-between">
                    <h5 class="mb-0 text-muted fw-bold">HUTECH Hospital System</h5>
                    <div class="d-flex align-items-center">
                        <span class="me-3 fw-medium">Xin chào, <span class="text-primary">@User.Identity?.Name</span></span>
                        <form class="form-inline m-0" asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                            <button type="submit" class="btn btn-sm btn-outline-danger px-3 rounded-pill fw-bold">
                                <i class="fa-solid fa-right-from-bracket me-1"></i> Đăng xuất
                            </button>
                        </form>
                    </div>
                </div>
            </nav>

            <div class="container-fluid p-4">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible bg-white shadow-sm border-0 border-start border-success border-5 fade show" role="alert">
                        <i class="fa-solid fa-check-circle text-success me-2"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
