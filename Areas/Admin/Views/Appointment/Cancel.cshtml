@model HUTECH_Hospital.Models.Appointment

@{
    ViewData["Title"] = "Hủy Lịch Hẹn";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card border-0 shadow rounded-4">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <i class="fa-solid fa-user-slash fa-4x text-danger mb-3"></i>
                    <h3 class="fw-bold text-danger">Quản Trị: Hủy Phiếu Khám #@Model.Id</h3>
                </div>

                <div class="bg-light p-3 rounded-3 mb-4 border-start border-danger border-4">
                    <p class="mb-1">Bệnh nhân: <strong>@Model.Patient?.FullName</strong></p>
                    <p class="mb-1">Bác sĩ tiếp nhận: <strong>@Model.Doctor?.FullName</strong></p>
                    <p class="mb-0">Khung giờ: <strong class="text-primary">@Model.AppointmentDate.ToString("dd/MM/yyyy") - @Model.AppointmentTime.ToString(@"hh\:mm")</strong></p>
                </div>

                <form asp-action="Cancel" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    
                    <div class="mb-4">
                        <label for="cancelReason" class="form-label fw-bold">Lý do từ chối / hủy lịch (bắt buộc): <span class="text-danger">*</span></label>
                        <textarea id="cancelReason" name="cancelReason" class="form-control" rows="3" placeholder="Nhập lý do gửi đến bệnh nhân..." required></textarea>
                    </div>

                    <div class="d-flex gap-3">
                        <a asp-action="Index" class="btn btn-light border rounded-pill w-50 p-2 text-dark">Hủy thao tác</a>
                        <button type="submit" class="btn btn-danger rounded-pill w-50 p-2 fw-bold shadow-sm">
                            <i class="fa-solid fa-ban me-2"></i>Xác nhận Hủy
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
