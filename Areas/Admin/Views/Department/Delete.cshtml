@model HUTECH_Hospital.Models.Department
@{
    ViewData["Title"] = "Xoá Khóa Chuyên Khoa";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" class="btn btn-light rounded-circle shadow-sm" style="width:40px;height:40px;padding:8px;"><i class="fa-solid fa-arrow-left"></i></a>
    <h2 class="fw-bold m-0 text-danger">Xóa / Vô hiệu hóa Chuyên Khoa</h2>
</div>

<div class="row">
    <div class="col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 border-start border-danger border-4">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="fa-solid fa-triangle-exclamation text-warning mb-3" style="font-size:3rem;"></i>
                    <h4 class="fw-bold text-dark">Bạn có chắc chắn?</h4>
                    <p class="text-muted">Hành động này sẽ vô hiệu hoá <b>Khoa @Model.Name</b>.</p>
                </div>
                
                <div class="bg-light p-3 rounded-3 mb-4 text-center">
                    @if(Model.Doctors.Any())
                    {
                        <span class="text-danger fw-bold"><i class="fa-solid fa-circle-exclamation me-2"></i>Chuyên khoa này đang có @Model.Doctors.Count Bác sĩ.</span>
                        <p class="small text-muted m-0 mt-1">Hệ thống sẽ không xóa vĩnh viễn để bảo toàn dữ liệu, mà chỉ thay đổi trạng thái sang "Ngừng Hoạt Động".</p>
                    }
                    else
                    {
                        <span class="text-danger fw-bold"><i class="fa-solid fa-trash me-2"></i>Khoa chưa có dữ liệu. Sẽ bị xóa vĩnh viễn.</span>
                    }
                </div>

                <form asp-action="Delete" method="post" class="d-flex gap-2">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger flex-grow-1 rounded-pill fw-bold shadow-sm">Xác nhận thực thi</button>
                    <a asp-action="Index" class="btn btn-light flex-grow-1 rounded-pill fw-bold shadow-sm">Hủy bỏ</a>
                </form>
            </div>
        </div>
    </div>
</div>
