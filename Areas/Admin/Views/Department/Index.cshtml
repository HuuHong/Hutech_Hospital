@model IEnumerable<HUTECH_Hospital.Models.Department>
@{
    ViewData["Title"] = "Quản lý Chuyên Khoa";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark">Chuyên Khoa</h2>
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm"><i class="fa-solid fa-plus me-2"></i> Thêm mới</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Hình ảnh</th>
                        <th>Tên chuyên khoa</th>
                        <th>Trạng thái</th>
                        <th>Bác sĩ</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" class="rounded" width="50" height="50" style="object-fit:cover;" />
                                }
                                else
                                {
                                    <div class="bg-light rounded d-flex align-items-center justify-content-center text-muted" style="width:50px; height:50px;">
                                        <i class="fa-solid fa-image"></i>
                                    </div>
                                }
                            </td>
                            <td class="fw-bold text-dark">@item.Name</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill">Đã khóa</span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-primary-subtle text-primary rounded-pill">@item.Doctors.Count BS</span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Chi tiết"><i class="fa-solid fa-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Sửa"><i class="fa-solid fa-pen"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Xóa"><i class="fa-solid fa-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if(!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">Chưa có chuyên khoa nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
