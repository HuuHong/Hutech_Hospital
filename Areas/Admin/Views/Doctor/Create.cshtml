@model HUTECH_Hospital.ViewModels.DoctorCreateViewModel
@{
    ViewData["Title"] = "Thêm Bác Sĩ Mới";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" class="btn btn-light rounded-circle shadow-sm" style="width:40px;height:40px;padding:8px;"><i class="fa-solid fa-arrow-left"></i></a>
    <h2 class="fw-bold m-0 text-dark">Lập Thẻ Bác Sĩ Mới</h2>
</div>

<form asp-action="Create" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm rounded-3"></div>

    <div class="row g-4">
        <!-- Cột Phải: Thông tin Chuyên môn & Tài khoản -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-bottom p-4">
                    <h5 class="fw-bold m-0"><i class="fa-solid fa-user-doctor text-primary me-2"></i>Hồ sơ chuyên môn & Phân công</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="DoctorCode" class="form-label fw-bold"></label>
                            <input asp-for="DoctorCode" class="form-control bg-light" placeholder="VD: BS001" />
                            <span asp-validation-for="DoctorCode" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DepartmentId" class="form-label fw-bold"></label>
                            <select asp-for="DepartmentId" asp-items="Model.Departments" class="form-select bg-light">
                                <option value="">-- Chọn chuyên khoa --</option>
                            </select>
                            <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Degree" class="form-label fw-bold"></label>
                            <select asp-for="Degree" class="form-select bg-light">
                                <option value="">-- Chọn học vị --</option>
                                <option value="Bác sĩ (BS)">Bác sĩ (BS)</option>
                                <option value="Thạc sĩ, Bác sĩ (ThS. BS)">Thạc sĩ, Bác sĩ (ThS. BS)</option>
                                <option value="Tiến sĩ, Bác sĩ (TS. BS)">Tiến sĩ, Bác sĩ (TS. BS)</option>
                                <option value="Bác sĩ chuyên khoa I (BS CKI)">Bác sĩ chuyên khoa I (BS CKI)</option>
                                <option value="Bác sĩ chuyên khoa II (BS CKII)">Bác sĩ chuyên khoa II (BS CKII)</option>
                                <option value="Phó Giáo sư, Tiến sĩ, Bác sĩ (PGS. TS. BS)">Phó Giáo sư, Tiến sĩ, Bác sĩ (PGS. TS. BS)</option>
                                <option value="Giáo sư, Tiến sĩ, Bác sĩ (GS. TS. BS)">Giáo sư, Tiến sĩ, Bác sĩ (GS. TS. BS)</option>
                            </select>
                            <span asp-validation-for="Degree" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Specialization" class="form-label fw-bold"></label>
                            <input asp-for="Specialization" class="form-control bg-light" placeholder="VD: Khám bệnh đa khoa..." />
                            <span asp-validation-for="Specialization" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ExperienceYears" class="form-label fw-bold"></label>
                            <input asp-for="ExperienceYears" class="form-control bg-light" type="number" min="0" />
                            <span asp-validation-for="ExperienceYears" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-bottom p-4">
                    <h5 class="fw-bold m-0"><i class="fa-solid fa-address-card text-info me-2"></i>Thông tin cá nhân & Đăng nhập</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label asp-for="FullName" class="form-label fw-bold"></label>
                            <input asp-for="FullName" class="form-control bg-light" placeholder="Tên bệnh viện hiển thị" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-bold"></label>
                            <input asp-for="Email" class="form-control bg-light" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label fw-bold"></label>
                            <input asp-for="PhoneNumber" class="form-control bg-light" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label fw-bold"></label>
                            <input asp-for="Password" class="form-control bg-light" type="password" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ConfirmPassword" class="form-label fw-bold"></label>
                            <input asp-for="ConfirmPassword" class="form-control bg-light" type="password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Gender" class="form-label fw-bold"></label>
                            <select asp-for="Gender" class="form-select bg-light">
                                <option value="Nam">Nam</option>
                                <option value="Nữ">Nữ</option>
                                <option value="Khác">Khác</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DateOfBirth" class="form-label fw-bold"></label>
                            <input asp-for="DateOfBirth" class="form-control bg-light" type="date" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Address" class="form-label fw-bold"></label>
                            <input asp-for="Address" class="form-control bg-light" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Cột Trái: Avatar & Trạng thái -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4 text-center">
                    <div class="bg-light rounded-circle mx-auto d-flex align-items-center justify-content-center mb-3" style="width:140px;height:140px;font-size:4rem;color:#ccc;">
                        <i class="fa-solid fa-user-doctor"></i>
                    </div>
                    <div class="mb-4 text-start">
                        <label asp-for="AvatarFile" class="form-label fw-bold">Ảnh Y Sĩ</label>
                        <input asp-for="AvatarFile" type="file" class="form-control form-control-sm bg-light" accept=".jpg,.png,.webp" />
                    </div>
                    <div class="text-start mb-3">
                        <label asp-for="Description" class="form-label fw-bold"></label>
                        <textarea asp-for="Description" class="form-control bg-light" rows="4" placeholder="Giới thiệu bản thân..."></textarea>
                    </div>
                    <hr />
                    <div class="form-check form-switch text-start mb-4">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" checked>
                        <label class="form-check-label fw-bold" asp-for="IsActive">Kích hoạt Bác sĩ</label>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary rounded-pill fw-bold shadow-sm py-2">Xác nhận Tạo hồ sơ</button>
                        <a asp-action="Index" class="btn btn-light rounded-pill fw-bold py-2">Hủy bỏ</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
