@model IEnumerable<HUTECH_Hospital.Models.Doctor>
@{
    ViewData["Title"] = "Đội ngũ Bác sĩ";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var departments = ViewBag.Departments as IEnumerable<HUTECH_Hospital.Models.Department>;
}

<section class="page-hero compact-page-hero">
    <div class="medical-bg-orbs">
        <div class="orb orb-1"></div>
        <div class="orb orb-3"></div>
    </div>
    <div class="mesh-grid"></div>

    <div class="container text-center reveal-up position-relative" style="z-index: 10;">
        <h1 class="section-title">Danh Y Y Học</h1>
        <p class="section-subtitle">Gặp gỡ đội ngũ Y, Bác sĩ, và các Chuyên gia đầu ngành tại Bệnh viện số HUTECH.</p>
        
        <form asp-action="Index" method="get" class="mx-auto glass-card p-3 rounded-4" style="max-width: 800px;">
            <div class="row g-2">
                <div class="col-md-5">
                    <select name="departmentId" class="form-select border-0 px-4 py-3 rounded-4 shadow-sm">
                        <option value="">-- Tất cả chuyên khoa --</option>
                        @if(departments != null)
                        {
                            foreach(var dp in departments)
                            {
                                if(ViewData["DepartmentId"]?.ToString() == dp.Id.ToString())
                                {
                                    <option value="@dp.Id" selected>@dp.Name</option>
                                }
                                else
                                {
                                    <option value="@dp.Id">@dp.Name</option>
                                }
                            }
                        }
                    </select>
                </div>
                <div class="col-md-5">
                    <input type="text" name="keyword" value="@ViewData["Keyword"]" class="form-control border-0 px-4 py-3 rounded-4 shadow-sm" placeholder="Tìm theo Tên hoặc Chuyên môn...">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-medical-primary w-100 rounded-4 py-3 h-100"><i class="fa-solid fa-filter"></i></button>
                </div>
            </div>
        </form>
    </div>
</section>

<section class="page-section">
    <div class="container py-5">
        @if(Model != null && Model.Any())
        {
            <div class="row g-4">
                @foreach (var doc in Model)
                {
                    <div class="col-md-6 col-lg-4 reveal-up">
                        <div class="glass-card doctor-card h-100 shadow-sm border-0 rounded-4">
                            <div class="avatar-wrap rounded-top-4">
                                @if (!string.IsNullOrEmpty(doc.AvatarUrl))
                                {
                                    <img src="@doc.AvatarUrl" class="w-100" />
                                }
                                else
                                {
                                    <img src="https://ui-avatars.com/api/?name=@(doc.FullName)&background=random&size=300" class="w-100 object-fit-cover" />
                                }
                                <div class="position-absolute bottom-0 start-0 w-100 p-3" style="background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);">
                                    <span class="badge bg-primary px-3 py-2 rounded-pill">@(doc.Degree ?? "BS")</span>
                                </div>
                            </div>
                            <div class="info text-start p-4 bg-white rounded-bottom-4">
                                <h4 class="fw-bold text-dark mb-1">@doc.FullName</h4>
                                <p class="text-primary mb-3"><i class="fa-solid fa-stethoscope me-2"></i>@(doc.Department?.Name ?? "Chưa phân khoa")</p>
                                
                                <hr class="text-muted opacity-25" />
                                <div class="d-flex justify-content-between text-muted small mb-3">
                                    <span><i class="fa-solid fa-briefcase me-1"></i>@doc.ExperienceYears năm kinh nghiệm</span>
                                    <span><i class="fa-solid fa-star text-warning"></i> Chuyên gia</span>
                                </div>

                                <a asp-controller="Doctors" asp-action="Details" asp-route-id="@doc.Id" class="btn btn-medical-outline rounded-pill w-100 mb-2">Xem hồ sơ</a>
                                <a asp-controller="Appointment" asp-action="Create" asp-route-doctorId="@doc.Id" class="btn btn-medical-primary rounded-pill w-100">Đặt lịch khám</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state text-center py-5">
                <div class="bg-light rounded-circle mx-auto d-flex align-items-center justify-content-center text-muted mb-4" style="width:120px; height:120px; font-size:3rem;">
                    <i class="fa-solid fa-user-doctor"></i>
                </div>
                <h4>Chưa có bác sĩ nào.</h4>
                <a asp-action="Index" class="btn btn-primary rounded-pill px-4 shadow-sm mt-3">Hủy tìm kiếm</a>
            </div>
        }
    </div>
</section>
