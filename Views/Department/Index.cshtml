@model IEnumerable<HUTECH_Hospital.Models.Department>
@{
    ViewData["Title"] = "Chuyên Khoa";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-hero compact-page-hero">
    <div class="medical-bg-orbs">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
    </div>
    <div class="mesh-grid"></div>

    <div class="container text-center reveal-up position-relative" style="z-index: 10;">
        <h1 class="section-title">Chuyên khoa khám bệnh</h1>
        <p class="section-subtitle">HUTECH Hospital cung cấp đầy đủ các chuyên khoa y tế chuyên sâu với trang thiết bị tối tân, cùng đội ngũ chuyên gia hàng đầu luôn sẵn sàng chăm sóc sức khỏe cho bạn và gia đình.</p>
        
        <form asp-action="Index" method="get" class="mx-auto mt-4" style="max-width: 600px;">
            <div class="input-group input-group-lg shadow border rounded-pill overflow-hidden bg-white p-1">
                <input type="text" name="keyword" value="@ViewData["Keyword"]" class="form-control border-0 px-4" placeholder="Tìm kiếm tên khoa...">
                <button type="submit" class="btn btn-medical-primary rounded-pill px-4"><i class="fa-solid fa-magnifying-glass me-2"></i>Tìm kiếm</button>
            </div>
        </form>
    </div>
</section>

<section class="page-section">
    <div class="container py-5">
        @if(Model != null && Model.Any())
        {
            <div class="row g-4">
                @foreach (var item in Model)
                {
                    <div class="col-md-6 col-lg-4 reveal-up">
                        <div class="glass-card h-100 text-center p-4">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" class="rounded-circle shadow-sm mb-3 border border-3 border-white" width="100" height="100" style="object-fit:cover;" />
                            }
                            else
                            {
                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle shadow-sm mb-3 mx-auto d-flex align-items-center justify-content-center" style="width:100px; height:100px; font-size:2.5rem;">
                                    <i class="fa-solid fa-stethoscope"></i>
                                </div>
                            }
                            <h4 class="fw-bold mb-2">@item.Name</h4>
                            <p class="text-muted small mb-4" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">@item.Description</p>
                            
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-medical-outline rounded-pill px-4 w-100 mb-2">Xem chi tiết Khoa</a>
                            
                            <div class="text-muted small">
                                <i class="fa-solid fa-user-doctor me-1 text-primary"></i> Đang có <span class="fw-bold">@(item.Doctors?.Count(d=>d.IsActive) ?? 0)</span> Bác sĩ trực thuộc
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state py-5 text-center">
                <i class="fa-solid fa-folder-open fs-1 mb-3 text-muted"></i>
                <h4>Chưa có chuyên khoa nào.</h4>
                @if (!string.IsNullOrEmpty(ViewData["Keyword"]?.ToString()))
                {
                    <a asp-action="Index" class="btn btn-medical-outline rounded-pill mt-3">Hủy tìm kiếm</a>
                }
            </div>
        }
    </div>
</section>
