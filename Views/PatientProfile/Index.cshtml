@model HUTECH_Hospital.ViewModels.PatientProfileViewModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="container py-5 mt-5">
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="glass-card text-center shadow-sm">
                <img src="@(string.IsNullOrEmpty(Model.AvatarUrl) ? "https://cdn-icons-png.flaticon.com/512/847/847969.png" : Model.AvatarUrl)" 
                     class="rounded-circle mb-3" width="120" height="120" style="object-fit: cover;" alt="Avatar" />
                <h5 class="fw-bold">@Model.FullName</h5>
                <p class="text-muted small mb-2"><i class="fa-solid fa-envelope me-1"></i> Patient Account</p>
                @if(!string.IsNullOrEmpty(Model.StudentCode)) {
                    <span class="badge bg-primary rounded-pill px-3 py-2">MSSV: @Model.StudentCode</span>
                }
            </div>
            
            <div class="glass-card shadow-sm mt-4 p-3 border-0 rounded-4">
                <ul class="nav flex-column gap-2">
                    <li class="nav-item">
                        <a class="nav-link active fw-bold text-primary bg-light rounded" href="/PatientProfile/Index"><i class="fa-regular fa-user me-2"></i> Thông tin chung</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-muted" href="#"><i class="fa-solid fa-list-check me-2"></i> Lịch hẹn khám</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-muted" href="#"><i class="fa-solid fa-folder-open me-2"></i> Hồ sơ bệnh án</a>
                    </li>
                </ul>
            </div>
        </div>
        
        <div class="col-md-8">
            <div class="glass-card shadow-sm page-card px-4 py-5">
                <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                    <h4 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-circle-info text-primary me-2"></i> Chi tiết hồ sơ</h4>
                    <a href="/PatientProfile/Edit" class="btn btn-sm btn-medical-outline"><i class="fa-solid fa-pen-to-square me-1"></i> Chỉnh sửa</a>
                </div>
                
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="row mt-3">
                    <div class="col-sm-4">
                        <p class="text-muted small fw-bold mb-1">Họ và tên</p>
                        <p class="fw-medium">@Model.FullName</p>
                    </div>
                    <div class="col-sm-4">
                        <p class="text-muted small fw-bold mb-1">Giới tính</p>
                        <p class="fw-medium">@(Model.Gender ?? "Chưa cập nhật")</p>
                    </div>
                    <div class="col-sm-4">
                        <p class="text-muted small fw-bold mb-1">Ngày sinh</p>
                        <p class="fw-medium">@(Model.DateOfBirth?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</p>
                    </div>
                </div>
                
                <div class="row mt-4">
                    <div class="col-sm-4">
                        <p class="text-muted small fw-bold mb-1">Số điện thoại</p>
                        <p class="fw-medium">@(Model.PhoneNumber ?? "Chưa cập nhật")</p>
                    </div>
                    <div class="col-sm-8">
                        <p class="text-muted small fw-bold mb-1">Địa chỉ cư trú</p>
                        <p class="fw-medium">@(Model.Address ?? "Chưa cập nhật")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
