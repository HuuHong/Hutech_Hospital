@model HUTECH_Hospital.Models.MedicalRecord
@{
    ViewData["Title"] = "Chi tiết Hồ sơ Khám";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-section bg-light py-5">
    <div class="container mt-5 pt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold m-0"><i class="fa-solid fa-file-medical text-primary me-2"></i> Hồ sơ số #@Model.Id</h2>
            <a href="/MedicalRecord/Index" class="btn btn-outline-secondary rounded-pill px-4"><i class="fa-solid fa-arrow-left me-2"></i> Trở về danh sách</a>
        </div>

        <div class="row">
            <div class="col-lg-8 mb-4">
                <div class="card border-0 shadow-sm rounded-4 h-100 page-card">
                    <div class="card-header bg-white border-bottom py-3">
                        <h5 class="m-0 fw-bold">Thông tin Khám bệnh</h5>
                    </div>
                    <div class="card-body p-4 p-md-5">
                        <div class="row mb-4 bg-light p-3 rounded-3">
                            <div class="col-sm-6 mb-3 mb-sm-0">
                                <small class="text-muted text-uppercase fw-bold d-block mb-1">Mã ca khám (Appointment)</small>
                                <span class="fw-bold text-primary fs-5">#@Model.AppointmentId</span>
                            </div>
                            <div class="col-sm-6">
                                <small class="text-muted text-uppercase fw-bold d-block mb-1">Ngày cập nhật hồ sơ</small>
                                <span class="fw-bold text-dark fs-5">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <p class="text-muted mb-1">Triệu chứng khai báo:</p>
                            <div class="fs-5 text-dark">@(string.IsNullOrEmpty(Model.Symptoms) ? "Không có" : Model.Symptoms)</div>
                        </div>
                        <div class="mb-4 text-primary bg-primary bg-opacity-10 p-3 rounded-3 border-start border-primary border-4">
                            <p class="text-muted mb-1 text-uppercase fw-bold" style="font-size: 0.8rem;">Chẩn đoán chính thức:</p>
                            <div class="fs-4 fw-bold">@Model.Diagnosis</div>
                        </div>
                        <div class="mb-4">
                            <p class="text-muted mb-1">Hướng điều trị:</p>
                            <div class="fs-6 text-dark">@(string.IsNullOrEmpty(Model.Treatment) ? "Không có" : Model.Treatment)</div>
                        </div>
                        <div class="mb-4">
                            <p class="text-muted mb-1">Ghi chú của bác sĩ:</p>
                            <div class="fs-6 text-dark fst-italic">@(string.IsNullOrEmpty(Model.DoctorNote) ? "Không có ghi chú thêm." : Model.DoctorNote)</div>
                        </div>
                        
                        <div class="row mt-5">
                            <div class="col-12">
                                <div class="p-3 bg-warning bg-opacity-10 border border-warning rounded-3 d-flex align-items-center">
                                    <i class="fa-solid fa-calendar-check text-warning fa-2x me-3"></i>
                                    <div>
                                        <div class="fw-bold">Lịch hẹn tái khám</div>
                                        @if (Model.ReExaminationDate.HasValue)
                                        {
                                            <div class="text-dark">@Model.ReExaminationDate.Value.ToString("dd MMMM, yyyy")</div>
                                        }
                                        else
                                        {
                                            <div class="text-muted">Không có yêu cầu tái khám</div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-4 mb-4">
                <div class="card border-0 shadow-sm rounded-4 mb-4 page-card">
                    <div class="card-body p-4 text-center">
                        <img src="@(string.IsNullOrEmpty(Model.Doctor?.AvatarUrl) ? "https://ui-avatars.com/api/?name=" + Model.Doctor?.FullName + "&background=random" : Model.Doctor.AvatarUrl)" class="rounded-circle mb-3 border shadow-sm" width="100" height="100" style="object-fit:cover"/>
                        <h5 class="fw-bold mb-1">BS. @Model.Doctor?.FullName</h5>
                        <p class="text-primary small mb-3">@Model.Doctor?.Specialization</p>
                        <a href="/Doctor/Details/@Model.DoctorId" class="btn btn-sm btn-outline-primary rounded-pill px-3">Xem hồ sơ bác sĩ</a>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4 page-card" style="background: linear-gradient(145deg, #ffffff, var(--medical-soft));">
                    <div class="card-header bg-transparent border-bottom-0 pt-4 pb-0">
                        <h5 class="fw-bold text-success"><i class="fa-solid fa-pills me-2"></i>Đơn Thuốc Tự Động</h5>
                    </div>
                    <div class="card-body">
                        @if (Model.Prescription != null && Model.Prescription.PrescriptionDetails.Any())
                        {
                            <ul class="list-group list-group-flush rounded-3">
                                @foreach (var pd in Model.Prescription.PrescriptionDetails)
                                {
                                    <li class="list-group-item bg-transparent px-0 border-bottom">
                                        <div class="d-flex justify-content-between align-items-start mb-1">
                                            <span class="fw-bold text-dark">@pd.Medicine?.Name</span>
                                            <span class="badge bg-secondary rounded-pill">@pd.Quantity @pd.Medicine?.Unit</span>
                                        </div>
                                        <small class="text-muted d-block mb-1"><i class="fa-solid fa-circle-dot fa-xs text-primary me-1"></i> @pd.Dosage</small>
                                        <small class="text-muted d-block"><i class="fa-regular fa-clock fa-xs text-success me-1"></i> @pd.Usage</small>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="text-center text-muted py-4">
                                <i class="fa-solid fa-prescription-bottle-medical fs-3 opacity-25 mb-2"></i>
                                <p class="mb-0 small">Không có thuốc được kê<br>trong ca khám này.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
