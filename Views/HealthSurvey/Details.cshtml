@model HUTECH_Hospital.Models.HealthSurvey

@{
    ViewData["Title"] = "Thông tin Khảo sát Sức khỏe";
}

<style>
    .survey-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: none;
        border-radius: 1.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        overflow: hidden;
    }
    .survey-card-header {
        background: linear-gradient(135deg, #023e8a, #0077b6);
        color: white;
        padding: 2rem;
    }
    .data-label {
        font-size: 0.85rem;
        text-transform: uppercase;
        color: #6c757d;
        font-weight: 600;
        margin-bottom: 0.3rem;
    }
    .data-value {
        font-size: 1.1rem;
        font-weight: 500;
        color: #212529;
        margin-bottom: 1.5rem;
    }
    .section-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: rgba(0, 119, 182, 0.1);
        color: #0077b6;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        margin-bottom: 1rem;
    }
    .badge-condition {
        background: rgba(0, 180, 216, 0.15);
        color: #0077b6;
        padding: 8px 15px;
        border-radius: 50px;
        font-weight: 600;
        margin-right: 5px;
        margin-bottom: 5px;
        display: inline-block;
    }
</style>

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="survey-card" data-aos="fade-up">
                <div class="survey-card-header text-center position-relative">
                    <h2 class="fw-bold mb-2"><i class="fa-solid fa-file-medical me-3"></i>Hồ Sơ Sức Khỏe Cá Nhân</h2>
                    <p class="mb-0 opacity-75">Cập nhật lần cuối: @Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? @Model.CreatedAt.ToString("dd/MM/yyyy")</p>
                    <a asp-action="Edit" class="btn btn-light rounded-pill position-absolute" style="top: 2rem; right: 2rem; font-weight: 600;">
                        <i class="fa-solid fa-pen"></i> Chỉnh sửa
                    </a>
                </div>
                
                <div class="card-body p-5">
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="section-icon"><i class="fa-solid fa-user-doctor"></i></div>
                            <h5 class="fw-bold text-primary mb-4">Thông số cơ bản</h5>
                            
                            <div class="data-label">Ngày sinh</div>
                            <div class="data-value">@(Model.DateOfBirth?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</div>
                            
                            <div class="data-label">Giới tính</div>
                            <div class="data-value">@(Model.Gender ?? "Chưa cập nhật")</div>
                            
                            <div class="data-label">Chiều cao / Cân nặng</div>
                            <div class="data-value">@(Model.Height?.ToString() ?? "--") cm / @(Model.Weight?.ToString() ?? "--") kg</div>
                            
                            <div class="data-label">Nhóm máu</div>
                            <div class="data-value">
                                @if(!string.IsNullOrEmpty(Model.BloodType)) {
                                    <span class="badge bg-danger rounded-pill px-3 py-2 fs-6">@Model.BloodType</span>
                                } else {
                                    <span>--</span>
                                }
                            </div>
                        </div>
                        
                        <div class="col-md-8 border-start ps-md-5">
                            <div class="section-icon"><i class="fa-solid fa-book-medical"></i></div>
                            <h5 class="fw-bold text-primary mb-4">Bệnh sử & Di ứng</h5>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="data-label">Tiền sử bệnh cá nhân</div>
                                    <div class="data-value">@(string.IsNullOrEmpty(Model.PersonalHistory) ? "Không có" : Model.PersonalHistory)</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="data-label">Tiền sử bệnh gia đình</div>
                                    <div class="data-value">@(string.IsNullOrEmpty(Model.FamilyHistory) ? "Không có" : Model.FamilyHistory)</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="data-label">Dị ứng</div>
                                    <div class="data-value">@(string.IsNullOrEmpty(Model.Allergies) ? "Không có" : Model.Allergies)</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="data-label">Thuốc đang dùng</div>
                                    <div class="data-value">@(string.IsNullOrEmpty(Model.CurrentMedication) ? "Không có" : Model.CurrentMedication)</div>
                                </div>
                            </div>
                            
                            <div class="data-label mt-2">Bệnh nền</div>
                            <div class="data-value">
                                @if(!string.IsNullOrEmpty(Model.UnderlyingConditions)) {
                                    foreach(var cond in Model.UnderlyingConditions.Split(',')) {
                                        if(!string.IsNullOrWhiteSpace(cond)) {
                                            <span class="badge-condition">@cond.Trim()</span>
                                        }
                                    }
                                } else {
                                    <span>Không có</span>
                                }
                            </div>
                        </div>
                    </div>

                    <hr class="my-4 border-light">

                    <div class="row">
                        <div class="col-12">
                            <div class="section-icon bg-danger-subtle text-danger"><i class="fa-solid fa-stethoscope"></i></div>
                            <h5 class="fw-bold text-danger mb-4">Tình trạng hiện tại</h5>
                        </div>
                        
                        <div class="col-md-5">
                            <div class="data-label">Triệu chứng hiện tại</div>
                            <div class="data-value">@(string.IsNullOrEmpty(Model.CurrentSymptoms) ? "Bình thường" : Model.CurrentSymptoms)</div>
                        </div>
                        
                        <div class="col-md-4">
                            <div class="data-label">Thời gian xuất hiện</div>
                            <div class="data-value">@(string.IsNullOrEmpty(Model.SymptomDuration) ? "--" : Model.SymptomDuration)</div>
                        </div>
                        
                        <div class="col-md-3">
                            <div class="data-label">Mức độ khó chịu</div>
                            <div class="data-value">
                                @if(Model.DiscomfortLevel.HasValue) {
                                    int lvl = Model.DiscomfortLevel.Value;
                                    string color = lvl >= 7 ? "text-danger" : (lvl >= 4 ? "text-warning" : "text-success");
                                    <span class="@color fs-4 fw-bold">@lvl</span><span class="text-muted">/10</span>
                                } else {
                                    <span>--</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="text-center mt-5">
                <a asp-action="Index" asp-controller="Home" class="btn btn-outline-primary rounded-pill px-4 fw-bold">Về trang chủ</a>
                <a asp-action="Index" asp-controller="PatientProfile" class="btn btn-outline-secondary rounded-pill px-4 fw-bold ms-2">Hồ sơ của tôi</a>
            </div>
        </div>
    </div>
</div>
