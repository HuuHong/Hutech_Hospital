@using Microsoft.AspNetCore.Identity
@using HUTECH_Hospital.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<header>
    <nav class="navbar navbar-expand-lg fixed-top medical-navbar">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="fa-solid fa-square-h"></i> HUTECH_Hospital
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMedical" aria-controls="navbarMedical" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between" id="navbarMedical">
                <ul class="navbar-nav flex-grow-1 mx-lg-4">
                    <li class="nav-item"><a class="nav-link text-dark" href="/">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" href="/#about">Giới thiệu</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" href="/#departments">Chuyên khoa</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" href="/#doctors">Bác sĩ</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" href="/#process">Quy trình</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" href="/#booking">Đặt lịch</a></li>
                </ul>
                
                <ul class="navbar-nav align-items-center">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        var isPatient = User.IsInRole("Patient");
                        var isAdmin = User.IsInRole("Admin");
                        var isDoctor = User.IsInRole("Doctor");

                        if (isAdmin)
                        {
                            <li class="nav-item me-2">
                                <a class="btn btn-sm btn-dark" href="/Admin/Dashboard">Trang Quản Trị</a>
                            </li>
                        }
                        if (isDoctor)
                        {
                            <li class="nav-item me-2">
                                <a class="btn btn-sm btn-info text-white" href="/Doctor/Dashboard">Trang Bác Sĩ</a>
                            </li>
                        }
                        
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fa-regular fa-circle-user fs-5"></i> @User.Identity?.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="userDropdown">
                                @if (isPatient)
                                {
                                    <li><a class="dropdown-item" href="/PatientProfile/Index"><i class="fa-solid fa-id-card me-2 text-primary"></i>Hồ sơ cá nhân</a></li>
                                    <li><a class="dropdown-item" href="/Appointment/MyAppointments"><i class="fa-regular fa-calendar-check me-2 text-primary"></i>Lịch hẹn của tôi</a></li>
                                    <li><a class="dropdown-item" href="/MedicalRecord/Index"><i class="fa-solid fa-notes-medical me-2 text-primary"></i>Kết quả khám</a></li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form class="form-inline" asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item text-danger border-0 bg-transparent">
                                            <i class="fa-solid fa-right-from-bracket me-2"></i> Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Login">Đăng nhập</a>
                        </li>
                        <li class="nav-item ms-lg-2 mt-2 mt-lg-0">
                            <a class="btn btn-medical-primary btn-sm px-4 py-2" href="/Account/Register">Đăng ký</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>
