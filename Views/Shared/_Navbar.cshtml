@using Microsoft.AspNetCore.Identity
@using HUTECH_Hospital.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<header>
    <nav class="navbar navbar-expand-lg fixed-top medical-navbar">
        <div class="container-fluid px-lg-5">
            <a class="navbar-brand" href="/" style="padding: 0;">
                <img src="~/uploads/doctors/logo-dai-hoc-hutech_chu.png" alt="HUTECH Hospital Logo" style="height: 45px; object-fit: contain;" />
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMedical" aria-controls="navbarMedical" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between" id="navbarMedical">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 fw-medium">
                    <li class="nav-item mx-1 mx-lg-2">
                        <a class="nav-link active rounded-pill" aria-current="page" asp-area="" asp-controller="Home" asp-action="Index">Trang Chủ</a>
                    </li>
                    <li class="nav-item mx-1 mx-lg-2">
                        <a class="nav-link rounded-pill" asp-area="" asp-controller="Department" asp-action="Index">Chuyên Khoa</a>
                    </li>
                    <li class="nav-item mx-1 mx-lg-2">
                        <a class="nav-link rounded-pill" asp-area="" asp-controller="Doctors" asp-action="Index">Đội Ngũ Bác Sĩ</a>
                    </li>
                    <li class="nav-item mx-1 mx-lg-2">
                        <a class="nav-link rounded-pill" asp-area="" asp-controller="ServicePrice" asp-action="Index">Bảng Giá Dịch Vụ</a>
                    </li>
                    <li class="nav-item mx-1 mx-lg-2">
                        <a class="btn btn-medical-outline ms-2" style="padding: 0.6rem 1.2rem;" asp-area="" asp-controller="Appointment" asp-action="Create"><i class="fa-solid fa-stethoscope"></i> ĐẶT LỊCH KHÁM</a>
                    </li>
                </ul>
                
                <ul class="navbar-nav align-items-center">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        var isPatient = User.IsInRole("Patient");
                        var isAdmin = User.IsInRole("Admin");
                        var isDoctor = User.IsInRole("Doctor");

                        if (isAdmin)
                        {
                            <li class="nav-item me-2">
                                <a class="btn btn-sm btn-dark" href="/Admin/Dashboard">Trang Quản Trị</a>
                            </li>
                        }
                        if (isDoctor)
                        {
                            <li class="nav-item me-2">
                                <a class="btn btn-sm btn-info text-white" href="/Doctor/Dashboard">Trang Bác Sĩ</a>
                            </li>
                        }
                        
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fa-regular fa-circle-user fs-5"></i> @User.Identity?.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="userDropdown">
                                @if (isPatient)
                                {
                                    <li><a class="dropdown-item" asp-area="" asp-controller="PatientProfile" asp-action="Index"><i class="fa-solid fa-id-card me-2 text-primary"></i>Hồ sơ cá nhân</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Appointment" asp-action="MyAppointments"><i class="fa-regular fa-calendar-check me-2 text-primary"></i>Lịch hẹn khám</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="MedicalRecord" asp-action="Index"><i class="fa-solid fa-notes-medical me-2 text-primary"></i>Hồ sơ bệnh án</a></li>
                                    <li><a class="dropdown-item" href="/Notification/Index"><i class="fa-solid fa-bell me-2 text-warning"></i>Thông báo</a></li>
                                    <li><a class="dropdown-item" href="/Feedback/Create"><i class="fa-solid fa-comment-dots me-2 text-success"></i>Gửi phản hồi</a></li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form class="form-inline" asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item text-danger border-0 bg-transparent">
                                            <i class="fa-solid fa-right-from-bracket me-2"></i> Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Login">Đăng nhập</a>
                        </li>
                        <li class="nav-item ms-lg-2 mt-2 mt-lg-0">
                            <a class="btn btn-medical-primary" style="padding: 0.6rem 1.5rem;" href="/Account/Register">Đăng ký</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>
