@model IEnumerable<HUTECH_Hospital.Models.Appointment>

@{
    ViewData["Title"] = "Lịch khám của tôi";
}

<div class="container py-5 mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary"><i class="fa-solid fa-calendar-check me-2"></i>Danh Sách Lịch Hẹn</h2>
        <a asp-action="Create" class="btn btn-medical-primary rounded-pill fw-medium"><i class="fa-solid fa-plus me-1"></i>Đặt lịch mới</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted">
                        <tr>
                            <th class="ps-4">T.Gian Khám</th>
                            <th>Khoa - Bác sĩ</th>
                            <th>Lý do</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="fa-regular fa-calendar-xmark fa-3x mb-3 text-light"></i>
                                    <p class="mb-0">Bạn chưa có lịch hẹn nào.</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-medium">
                                        <div class="text-primary">@item.AppointmentDate.ToString("dd/MM/yyyy")</div>
                                        <small class="text-secondary"><i class="fa-regular fa-clock me-1"></i>@item.AppointmentTime.ToString(@"hh\:mm")</small>
                                    </td>
                                    <td>
                                        <div class="fw-bold">BS. @item.Doctor?.FullName</div>
                                        <span class="badge bg-light text-dark border">@item.Department?.Name</span>
                                    </td>
                                    <td>
                                        <div class="text-truncate" style="max-width: 200px;" title="@item.Reason">@item.Reason</div>
                                    </td>
                                    <td>
                                        @if (item.Status == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark"><i class="fa-solid fa-hourglass-half me-1"></i>Chờ xác nhận</span>
                                        }
                                        else if (item.Status == "Confirmed")
                                        {
                                            <span class="badge bg-success"><i class="fa-solid fa-check-double me-1"></i>Đã duyệt</span>
                                        }
                                        else if (item.Status == "Completed")
                                        {
                                            <span class="badge bg-info text-dark"><i class="fa-solid fa-notes-medical me-1"></i>Hoàn tất</span>
                                        }
                                        else if (item.Status == "Cancelled")
                                        {
                                            <span class="badge bg-danger"><i class="fa-solid fa-ban me-1"></i>Đã hủy</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Chi tiết"><i class="fa-regular fa-eye"></i></a>
                                            @if (item.Status == "Pending" || item.Status == "Confirmed")
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Dời lịch"><i class="fa-regular fa-calendar-days"></i></a>
                                                <a asp-action="Cancel" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Hủy lịch"><i class="fa-solid fa-xmark"></i></a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
