@model HUTECH_Hospital.Models.Appointment

@{
    ViewData["Title"] = "Hủy lịch khám";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card border-danger border border-2 rounded-4 shadow">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="fa-solid fa-triangle-exclamation fa-4x text-danger mb-3"></i>
                        <h3 class="fw-bold text-danger">Xác nhận Hủy Lịch Khám!</h3>
                        <p class="text-muted">Bạn có chắc chắn muốn hủy bỏ lịch hẹn khám này? Hành động này không thể hoàn tác.</p>
                    </div>

                    <div class="bg-light p-3 rounded-3 mb-4">
                        <p class="mb-1 fw-bold">Mã Phiếu: #@Model.Id</p>
                        <p class="mb-1 text-primary fw-medium"><i class="fa-solid fa-calendar me-2"></i>@Model.AppointmentDate.ToString("dd/MM/yyyy") lúc @Model.AppointmentTime.ToString(@"hh\:mm")</p>
                        <p class="mb-0"><i class="fa-solid fa-user-doctor me-2"></i>Khoa @Model.Department?.Name - BS. @Model.Doctor?.FullName</p>
                    </div>

                    <form asp-action="Cancel" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        
                        <div class="mb-4">
                            <label for="cancelReason" class="form-label fw-medium text-danger">Bệnh viện muốn biết lý do hủy của bạn: <span class="text-danger">*</span></label>
                            <textarea id="cancelReason" name="cancelReason" class="form-control border-danger" rows="2" placeholder="Ví dụ: bận việc đột xuất, đổi ý..." required></textarea>
                            <div class="invalid-feedback">
                                Vui lòng cho biết lý do hủy.
                            </div>
                        </div>

                        <div class="d-flex gap-3">
                            <a asp-action="MyAppointments" class="btn btn-secondary rounded-pill w-50 p-2">Giữ Lại Lịch Quay Về</a>
                            <button type="submit" class="btn btn-danger rounded-pill w-50 p-2 fw-bold shadow-sm">
                                Xác Nhận Hủy
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
