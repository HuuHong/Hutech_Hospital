@model HUTECH_Hospital.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="glass-card page-card shadow border-0">
                <div class="text-center mb-4">
                    <i class="fa-solid fa-user-shield fs-1 text-primary mb-2"></i>
                    <h3 class="fw-bold">Đăng nhập</h3>
                    <p class="text-muted small">Chào mừng bạn trở lại hệ thống y tế số</p>
                </div>

                <form asp-action="Login" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label small fw-bold text-muted"></label>
                        <input asp-for="Email" class="medical-input" placeholder="name@example.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label small fw-bold text-muted"></label>
                        <input asp-for="Password" class="medical-input" placeholder="Mật khẩu" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4 d-flex justify-content-between align-items-center">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label small text-muted">Ghi nhớ</label>
                        </div>
                        <a href="#" class="small text-decoration-none">Quên mật khẩu?</a>
                    </div>

                    <button type="submit" class="btn btn-medical-primary w-100 py-2 mb-3">Đăng nhập</button>

                    <div class="text-center small text-muted">
                        Chưa có tài khoản? <a href="/Account/Register" class="text-decoration-none fw-bold">Đăng ký ngay</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
