                    </div>
                    <div class="info">
                        <h5 class="fw-bold mb-1">BS Trần Thanh Bình</h5>
                        <p class="text-primary fw-medium small mb-2">Tim mạch</p>
                        <p class="text-muted small"><i class="fa-regular fa-clock me-1"></i> 8 năm kinh nghiệm</p>
                        <div class="d-flex gap-2 justify-content-center mt-3">
                            <a href="#" class="btn btn-sm btn-light border w-50">Xem hồ sơ</a>
                            <a href="#booking" class="btn btn-sm btn-medical-primary w-50">Đặt lịch</a>
