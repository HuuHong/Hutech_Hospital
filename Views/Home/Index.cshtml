@{
    ViewData["Title"] = "HUTECH_Hospital - Bệnh viện thông minh";
}

<!-- Hero Section -->
<section id="home" class="hospital-hero page-hero">
    <div class="medical-bg-orbs">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
        <div class="mesh-grid"></div>
    </div>
    
    <div class="container position-relative" style="z-index: 10;">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0 text-center text-lg-start">
                <div class="d-inline-flex align-items-center gap-2 px-3 py-2 rounded-pill bg-white shadow-sm mb-4" style="border: 1px solid var(--medical-soft)">
                    <span class="spinner-grow spinner-grow-sm text-primary" role="status" aria-hidden="true"></span>
                    <span class="font-weight-600 text-primary small">Y Tế Số Thông Minh</span>
                </div>
                
                <h1 class="display-3 fw-bolder mb-4" style="color: var(--medical-dark); letter-spacing: -1px;">
                    HUTECH_Hospital
                </h1>
                <h2 class="h4 text-muted mb-4 fw-normal line-height-base">
                    Nền tảng quản lý bệnh viện và đặt lịch khám thông minh cho HUTECH Khu E
                </h2>
                <p class="lead mb-5 text-secondary">
                    Kết nối bệnh nhân, bác sĩ và hệ thống quản trị trên một nền tảng y tế số hiện đại, nhanh chóng và an toàn.
                </p>
                
                <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center justify-content-lg-start mb-5">
                    <a asp-controller="Appointment" asp-action="Create" class="btn btn-medical-primary btn-lg">
                        <i class="fa-regular fa-calendar-check me-2"></i> Đặt lịch khám ngay
                    </a>
                    <a href="#doctors" class="btn btn-medical-outline btn-lg">
                        <i class="fa-solid fa-user-doctor me-2"></i> Tìm bác sĩ
                    </a>
                </div>
                
                <div class="row g-3">
                    <div class="col-sm-6 col-md-3">
                        <div class="stat-card p-3 d-flex flex-column align-items-center text-center">
                            <h3 class="fs-4 text-primary fw-bold mb-1">120+</h3>
                            <span class="small text-muted">Bác sĩ</span>
                        </div>
                    </div>
                    <div class="col-sm-6 col-md-3">
                        <div class="stat-card p-3 d-flex flex-column align-items-center text-center">
                            <h3 class="fs-4 text-primary fw-bold mb-1">8.000+</h3>
                            <span class="small text-muted">Bệnh nhân</span>
                        </div>
                    </div>
                    <div class="col-sm-6 col-md-3">
                        <div class="stat-card p-3 d-flex flex-column align-items-center text-center">
                            <h3 class="fs-4 text-primary fw-bold mb-1">18+</h3>
                            <span class="small text-muted">Chuyên khoa</span>
                        </div>
                    </div>
                    <div class="col-sm-6 col-md-3">
                        <div class="stat-card p-3 d-flex flex-column align-items-center text-center">
                            <h3 class="fs-4 text-primary fw-bold mb-1">98%</h3>
                            <span class="small text-muted">Hài lòng</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-6 position-relative hero-doctor-img d-none d-lg-block">
                <!-- Medical Technology Element: ECG Line -->
                <div class="position-absolute top-50 start-0 w-100 bg-white rounded p-3 shadow" style="transform: translateY(-50%); z-index: 5;">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="small fw-bold text-muted">Hệ thống giám sát nhịp tim (Mô phỏng)</span>
                        <span class="small fw-bold text-success"><i class="fa-solid fa-heart-pulse"></i> Hoạt động tốt</span>
                    </div>
                    <div class="ecg-line"></div>
                </div>
                <!-- Có thể thay bằng thẻ img mượn từ url nếu muốn -->
                <div class="doctor-placeholder shadow-lg border border-4 border-white"></div>
            </div>
        </div>
    </div>
</section>

<!-- About Section -->
<section id="about" class="page-section py-5 bg-white reveal">
    <div class="container">
        <div class="row align-items-center mb-5">
            <div class="col-lg-5 mb-4 mb-lg-0">
                <span class="text-primary fw-bold text-uppercase tracking-wide small mb-2 d-block">Về Chúng Tôi</span>
                <h2 class="section-title mb-4">Quản lý bệnh viện thông minh thế hệ mới</h2>
                <p class="text-muted">
                    HUTECH_Hospital áp dụng công nghệ số vào y tế, giúp đơn giản hóa quy trình đặt lịch, lưu trữ hồ sơ bệnh án điện tử an toàn. Tự động hóa các thao tác cho bệnh nhân lẫn bác sĩ.
                </p>
                <a href="#departments" class="btn btn-medical-outline mt-3">Tìm hiểu dịch vụ</a>
            </div>
            <div class="col-lg-6 offset-lg-1">
                <div class="row g-4">
                    <div class="col-sm-6 text-center">
                        <div class="p-4 bg-light rounded-4 page-card shadow-sm h-100 reveal-up">
                            <div class="fs-1 text-primary mb-3"><i class="fa-solid fa-notes-medical"></i></div>
                            <h5 class="fw-bold">Hồ sơ điện tử</h5>
                            <p class="text-muted small">Cập nhật nhanh, đồng bộ với nền tảng y tế số.</p>
                        </div>
                    </div>
                    <div class="col-sm-6 text-center">
                        <div class="p-4 bg-light rounded-4 page-card shadow-sm h-100 reveal-up" style="transition-delay: 0.1s">
                            <div class="fs-1 text-primary mb-3"><i class="fa-solid fa-bell"></i></div>
                            <h5 class="fw-bold">Thông báo tự động</h5>
                            <p class="text-muted small">Nhắc hẹn kịp thời qua email hoặc tin nhắn.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Departments Section -->
<section id="departments" class="page-section py-5 reveal">
    <div class="container mt-5">
        <div class="text-center">
            <h2 class="section-title">Chuyên khoa khám bệnh</h2>
            <p class="section-subtitle">Chúng tôi cung cấp đa dạng dịch vụ y tế với trang thiết bị hiện đại cùng đội ngũ chuyên gia hàng đầu</p>
        </div>
        
        <div class="row g-4 mt-2 justify-content-center">
            @if(ViewBag.Departments != null && ((IEnumerable<HUTECH_Hospital.Models.Department>)ViewBag.Departments).Any())
            {
                foreach(var dept in (IEnumerable<HUTECH_Hospital.Models.Department>)ViewBag.Departments)
                {
                    <div class="col-lg-4 col-md-6 col-sm-12">
                        <div class="glass-card page-card department-card border-0 h-100">
                            @if (!string.IsNullOrEmpty(dept.ImageUrl))
                            {
                                <div class="dept-icon p-0 overflow-hidden" style="border-radius: 50%;">
                                    <img src="@dept.ImageUrl" style="width: 100%; height: 100%; object-fit: cover;" />
                                </div>
                            }
                            else
                            {
                                <div class="dept-icon"><i class="fa-solid fa-stethoscope"></i></div>
                            }
                            <h5 class="fw-bold">@dept.Name</h5>
                            <p class="small text-muted" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@dept.Description</p>
                            <a asp-controller="Department" asp-action="Details" asp-route-id="@dept.Id" class="btn btn-sm btn-link text-decoration-none px-0 mt-auto">Xem chi tiết &rarr;</a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center text-muted">
                    <p>Hệ thống hiện đang cập nhật danh mục chuyên khoa.</p>
                </div>
            }
        </div>
        
        <div class="text-center mt-5">
            <a asp-controller="Department" asp-action="Index" class="btn btn-medical-outline rounded-pill px-4">Xem toàn bộ chuyên khoa</a>
        </div>
    </div>
</section>

<!-- Doctors Section -->
<section id="doctors" class="page-section py-5 bg-white reveal">
    <div class="container mt-5">
        <div class="text-center">
            <h2 class="section-title">Bác sĩ nổi bật</h2>
            <p class="section-subtitle">Gặp gỡ các chuyên gia xuất sắc đang trực tiếp khám chữa bệnh tại HUTECH_Hospital</p>
        </div>
        
        <div class="row g-4 mt-2 justify-content-center">
            @if(ViewBag.Doctors != null && ((IEnumerable<HUTECH_Hospital.Models.Doctor>)ViewBag.Doctors).Any())
            {
                foreach(var doc in (IEnumerable<HUTECH_Hospital.Models.Doctor>)ViewBag.Doctors)
                {
                    <div class="col-lg-3 col-md-6 border-0">
                        <div class="glass-card page-card medical-card doctor-card shadow-sm h-100">
                            <div class="avatar-wrap bg-light border-bottom border-4 border-primary">
                                @if(!string.IsNullOrEmpty(doc.AvatarUrl))
                                {
                                    <img src="@doc.AvatarUrl" alt="Doctor" class="img-fluid object-fit-cover w-100" />
                                }
                                else
                                {
                                    <img src="https://ui-avatars.com/api/?name=@(doc.FullName)&background=random&size=300" alt="Doctor" class="img-fluid w-100" />
                                }
                            </div>
                            <div class="info pt-3">
                                <h5 class="fw-bold text-dark mb-1">@doc.Degree @doc.FullName</h5>
                                <p class="text-primary fw-medium small mb-2"><i class="fa-solid fa-stethoscope me-1"></i>@(doc.Department?.Name ?? "N/A")</p>
                                <p class="text-muted small"><i class="fa-regular fa-clock me-1"></i> @doc.ExperienceYears năm kinh nghiệm</p>
                                <div class="d-flex gap-2 justify-content-center mt-3">
                                    <a asp-controller="Doctors" asp-action="Details" asp-route-id="@doc.Id" class="btn btn-sm btn-light border w-50">Hồ sơ</a>
                                    <a href="/Appointment/Create?doctorId=@doc.Id" class="btn btn-sm btn-medical-primary w-50">Đặt lịch</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center text-muted">
                    <p>Hệ thống hiện đang cập nhật danh bạ y sĩ.</p>
                </div>
            }
        </div>
        
        <div class="text-center mt-5">
            <a asp-controller="Doctors" asp-action="Index" class="btn btn-medical-outline rounded-pill px-4">Khám phá đội ngũ Y khoa</a>
        </div>
    </div>
</section>

<!-- Process Section -->
<section id="process" class="page-section py-5 reveal">
    <div class="container my-5">
        <div class="text-center">
            <h2 class="section-title">Quy trình đặt lịch đơn giản</h2>
            <p class="section-subtitle">Chỉ với 4 bước, bạn đã có ngay một lịch khám với chuyên gia y tế.</p>
        </div>
        <div class="row w-100 g-4 mx-0 mt-3 position-relative">
            <div class="col-lg-3 col-md-6 process-step reveal-up">
                <div class="step-icon"><i class="fa-solid fa-list"></i></div>
                <h5 class="fw-bold">1. Chọn chuyên khoa</h5>
                <p class="small text-muted">Lựa chọn chuyên khoa phù hợp với triệu chứng.</p>
            </div>
            <div class="col-lg-3 col-md-6 process-step reveal-up" style="transition-delay: 0.1s">
                <div class="step-icon"><i class="fa-solid fa-user-doctor"></i></div>
                <h5 class="fw-bold">2. Chọn bác sĩ</h5>
                <p class="small text-muted">Chọn bác sĩ yêu thích theo hồ sơ.</p>
            </div>
            <div class="col-lg-3 col-md-6 process-step reveal-up" style="transition-delay: 0.2s">
                <div class="step-icon"><i class="fa-regular fa-calendar-days"></i></div>
                <h5 class="fw-bold">3. Chọn ngày giờ</h5>
                <p class="small text-muted">Đặt lịch dựa vào lịch làm việc có sẵn.</p>
            </div>
            <div class="col-lg-3 col-md-6 process-step reveal-up" style="transition-delay: 0.3s">
                <div class="step-icon"><i class="fa-solid fa-circle-check"></i></div>
                <h5 class="fw-bold">4. Xác nhận</h5>
                <p class="small text-muted">Nhận ngay thông báo xác nhận qua Email.</p>
            </div>
        </div>
    </div>
</section>

<!-- Achievements Section -->
<section class="page-section hospital-achievements-section py-5 bg-white reveal" id="achievements">
    <div class="container">
        <div class="text-center mb-5">
            <span class="status-badge primary mb-3">Năng lực y tế số</span>
            <h2 class="section-title">Thành tựu và giá trị nổi bật của HUTECH_Hospital</h2>
            <p class="section-subtitle">
                Nền tảng hỗ trợ quản lý khám bệnh thông minh, tối ưu trải nghiệm cho sinh viên, bệnh nhân và đội ngũ y tế.
            </p>
        </div>

        <div class="row g-4 achievement-grid mb-5">
            <div class="col-lg-3 col-md-6 reveal-up">
                <div class="achievement-card glass-card text-center h-100 p-4">
                    <div class="achievement-icon mb-3">
                        <i class="fa-solid fa-calendar-check mt-3 mb-2" style="font-size: 2.5rem; color: var(--medical-primary);"></i>
                    </div>
                    <h3 class="fw-bold text-dark mb-1">8.000+</h3>
                    <h5 class="fw-bold text-primary mb-3">Lượt đặt lịch</h5>
                    <p class="small text-muted mb-0">Hỗ trợ sinh viên và bệnh nhân đặt lịch khám nhanh chóng, giảm thời gian chờ tại quầy.</p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 reveal-up" style="transition-delay: 0.1s">
                <div class="achievement-card glass-card text-center h-100 p-4">
                    <div class="achievement-icon mb-3">
                        <i class="fa-solid fa-user-doctor mt-3 mb-2" style="font-size: 2.5rem; color: var(--medical-primary);"></i>
                    </div>
                    <h3 class="fw-bold text-dark mb-1">120+</h3>
                    <h5 class="fw-bold text-primary mb-3">Nhân sự y tế</h5>
                    <p class="small text-muted mb-0">Đội ngũ bác sĩ, điều dưỡng và nhân sự vận hành được tổ chức theo quy trình chuyên nghiệp.</p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 reveal-up" style="transition-delay: 0.2s">
                <div class="achievement-card glass-card text-center h-100 p-4">
                    <div class="achievement-icon mb-3">
                        <i class="fa-solid fa-hospital mt-3 mb-2" style="font-size: 2.5rem; color: var(--medical-primary);"></i>
                    </div>
                    <h3 class="fw-bold text-dark mb-1">18+</h3>
                    <h5 class="fw-bold text-primary mb-3">Chuyên khoa</h5>
                    <p class="small text-muted mb-0">Đáp ứng nhu cầu khám tổng quát, chuyên khoa và tư vấn sức khỏe cho sinh viên.</p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 reveal-up" style="transition-delay: 0.3s">
                <div class="achievement-card glass-card text-center h-100 p-4">
                    <div class="achievement-icon mb-3">
                        <i class="fa-solid fa-heart-pulse mt-3 mb-2" style="font-size: 2.5rem; color: var(--medical-primary);"></i>
                    </div>
                    <h3 class="fw-bold text-dark mb-1">98%</h3>
                    <h5 class="fw-bold text-primary mb-3">Hài lòng</h5>
                    <p class="small text-muted mb-0">Tối ưu trải nghiệm khám bệnh bằng quy trình đặt lịch, thông báo và quản lý hồ sơ số.</p>
                </div>
            </div>
        </div>

        <div class="row align-items-center mt-5 g-5">
            <div class="col-lg-6 reveal-left">
                <div class="medical-info-panel glass-card p-4 p-md-5">
                    <span class="status-badge primary mb-3">Healthcare Technology</span>
                    <h3 class="fw-bold mb-4">Nền tảng y tế số cho môi trường đại học hiện đại</h3>
                    <p class="text-muted mb-4 line-height-base">
                        HUTECH_Hospital hướng đến việc số hóa quy trình khám bệnh, kết nối bệnh nhân,
                        bác sĩ và bộ phận quản trị trên một hệ thống thống nhất. Từ đặt lịch, quản lý hồ sơ,
                        theo dõi kết quả khám đến phản hồi dịch vụ, mọi thao tác đều được thiết kế để nhanh hơn,
                        minh bạch hơn và thuận tiện hơn.
                    </p>
                    <ul class="medical-check-list list-unstyled d-flex flex-column gap-3 mb-0">
                        <li><i class="fa-solid fa-circle-check text-success me-3"></i> <span class="text-secondary fw-medium">Quy trình đặt lịch rõ ràng, dễ sử dụng</span></li>
                        <li><i class="fa-solid fa-circle-check text-success me-3"></i> <span class="text-secondary fw-medium">Hồ sơ bệnh nhân được quản lý tập trung</span></li>
                        <li><i class="fa-solid fa-circle-check text-success me-3"></i> <span class="text-secondary fw-medium">Thông tin bác sĩ và chuyên khoa minh bạch</span></li>
                        <li><i class="fa-solid fa-circle-check text-success me-3"></i> <span class="text-secondary fw-medium">Tối ưu trải nghiệm cho sinh viên HUTECH</span></li>
                        <li><i class="fa-solid fa-circle-check text-success me-3"></i> <span class="text-secondary fw-medium">Giao diện thân thiện trên máy tính và điện thoại</span></li>
                    </ul>
                </div>
            </div>

            <div class="col-lg-6 reveal-right">
                <div class="healthcare-dashboard-card glass-card p-4 p-md-5 bg-light border-0" style="background: linear-gradient(145deg, #ffffff, var(--medical-soft)) !important;">
                    <div class="dashboard-header d-flex justify-content-between align-items-center mb-5">
                        <div>
                            <h4 class="fw-bold mb-1">Chỉ số vận hành y tế</h4>
                            <p class="text-muted small mb-0">Theo dõi hiệu quả hoạt động khám bệnh</p>
                        </div>
                        <div class="icon-circle bg-white shadow-sm p-3 rounded-circle d-flex align-items-center justify-content-center">
                            <i class="fa-solid fa-chart-line fs-4 text-primary"></i>
                        </div>
                    </div>

                    <div class="metric-container mb-4">
                        <div class="metric-row d-flex justify-content-between mb-2">
                            <span class="text-secondary fw-bold">Lịch hẹn được xử lý</span>
                            <strong class="text-dark">92%</strong>
                        </div>
                        <div class="metric-bar progress" style="height: 10px; border-radius: 10px; background-color: #e2e8f0;">
                            <div class="progress-bar bg-primary" role="progressbar" style="width: 92%; border-radius: 10px;"></div>
                        </div>
                    </div>

                    <div class="metric-container mb-4">
                        <div class="metric-row d-flex justify-content-between mb-2">
                            <span class="text-secondary fw-bold">Hồ sơ được số hóa</span>
                            <strong class="text-dark">87%</strong>
                        </div>
                        <div class="metric-bar progress" style="height: 10px; border-radius: 10px; background-color: #e2e8f0;">
                            <div class="progress-bar bg-info" role="progressbar" style="width: 87%; border-radius: 10px;"></div>
                        </div>
                    </div>

                    <div class="metric-container">
                        <div class="metric-row d-flex justify-content-between mb-2">
                            <span class="text-secondary fw-bold">Phản hồi tích cực</span>
                            <strong class="text-dark">98%</strong>
                        </div>
                        <div class="metric-bar progress" style="height: 10px; border-radius: 10px; background-color: #e2e8f0;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: 98%; border-radius: 10px;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Quick Booking Form -->
<section id="booking" class="page-section quick-booking-section py-5 my-5 reveal">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="glass-card form-card shadow-lg p-md-5">
                    <div class="text-center mb-4">
                        <i class="fa-solid fa-calendar-plus fs-1 text-primary mb-3"></i>
                        <h2 class="fw-bold">Đặt lịch khám nhanh</h2>
                        <p class="text-muted">Vui lòng điền thông tin để chúng tôi liên hệ xác nhận giờ ưu tiên.</p>
                    </div>
                    
                    <div class="row g-3 text-center">
                        <div class="col-12 text-center mt-4 mb-3">
                            <i class="fa-solid fa-stethoscope fa-4x text-muted mb-3 opacity-50"></i>
                            <h5 class="text-secondary fw-normal">Hệ thống đã nâng cấp chức năng Đặt lịch Điện tử</h5>
                        </div>
                        <div class="col-12 text-center mt-2">
                            <a asp-controller="Appointment" asp-action="Create" class="btn btn-medical-primary w-100 py-3 d-flex align-items-center justify-content-center fw-bold fs-5 shadow-sm rounded-pill">
                                <i class="fa-solid fa-calendar-check me-3"></i>ĐẶT LỊCH KHÁM CHÍNH THỨC TẠI ĐÂY
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
