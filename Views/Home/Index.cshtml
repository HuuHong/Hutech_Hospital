                </div>
            </div>
            <div class="col-lg-4 col-md-6 border-0">
                <div class="glass-card page-card medical-card doctor-card shadow-sm h-100">
                    <div class="avatar-wrap">
                        <img src="https://images.unsplash.com/photo-1622253692010-333f2da6031d?auto=format&fit=crop&w=400&q=80" alt="Doctor" class="img-fluid" />
                    </div>
                    <div class="info">
                        <h5 class="fw-bold mb-1">BS Lê Hoàng My</h5>
                        <p class="text-primary fw-medium small mb-2">Da liễu</p>
                        <p class="text-muted small"><i class="fa-regular fa-clock me-1"></i> 6 năm kinh nghiệm</p>
                        <div class="d-flex gap-2 justify-content-center mt-3">
                            <a href="#" class="btn btn-sm btn-light border w-50">Xem hồ sơ</a>
