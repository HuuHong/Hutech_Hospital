                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Process Section -->
<section id="process" class="page-section py-5 reveal">
    <div class="container my-5">
        <div class="text-center">
            <h2 class="section-title">Quy trình đặt lịch đơn giản</h2>
            <p class="section-subtitle">Chỉ với 4 bước, bạn đã có ngay một lịch khám với chuyên gia y tế.</p>
        </div>
        <div class="row w-100 g-4 mx-0 mt-3 position-relative">
            <div class="col-lg-3 col-md-6 process-step reveal-up">
                <div class="step-icon"><i class="fa-solid fa-list"></i></div>
                <h5 class="fw-bold">1. Chọn chuyên khoa</h5>
                <p class="small text-muted">Lựa chọn chuyên khoa phù hợp với triệu chứng.</p>
            </div>
            <div class="col-lg-3 col-md-6 process-step reveal-up" style="transition-delay: 0.1s">
                <div class="step-icon"><i class="fa-solid fa-user-doctor"></i></div>
                <h5 class="fw-bold">2. Chọn bác sĩ</h5>
                <p class="small text-muted">Chọn bác sĩ yêu thích theo hồ sơ.</p>
            </div>
            <div class="col-lg-3 col-md-6 process-step reveal-up" style="transition-delay: 0.2s">
                <div class="step-icon"><i class="fa-regular fa-calendar-days"></i></div>
                <h5 class="fw-bold">3. Chọn ngày giờ</h5>
                <p class="small text-muted">Đặt lịch dựa vào lịch làm việc có sẵn.</p>
            </div>
            <div class="col-lg-3 col-md-6 process-step reveal-up" style="transition-delay: 0.3s">
                <div class="step-icon"><i class="fa-solid fa-circle-check"></i></div>
                <h5 class="fw-bold">4. Xác nhận</h5>
                <p class="small text-muted">Nhận ngay thông báo xác nhận qua Email.</p>
            </div>
        </div>
    </div>
</section>

<!-- Roles Section: Patient / Doctor / Admin -->
<section id="patient-area" class="page-section py-5 bg-white reveal">
    <div class="container">
        <!-- Patient Area -->
        <div class="row align-items-center mb-5 reveal-left">
            <div class="col-md-6 order-2 order-md-1">
                <img src="https://images.unsplash.com/photo-1576091160550-2173ff9e5eb3?auto=format&fit=crop&q=80&w=600" class="img-fluid rounded-4 shadow" alt="Patient Area">
            </div>
            <div class="col-md-6 order-1 order-md-2 mb-4 mb-md-0 px-lg-5">
                <span class="status-badge primary mb-3">Dành cho Bệnh nhân</span>
                <h2 class="fw-bold mb-4">Quản lý hồ sơ cá nhân mượt mà</h2>
                <ul class="list-unstyled d-flex flex-column gap-3 text-muted">
                    <li><i class="fa-solid fa-check text-primary me-2"></i> Đăng ký tài khoản hệ thống</li>
                    <li><i class="fa-solid fa-check text-primary me-2"></i> Đặt lịch khám, quản lý hồ sơ sức khỏe</li>
                    <li><i class="fa-solid fa-check text-primary me-2"></i> Xem kết quả khám, đơn thuốc</li>
                    <li><i class="fa-solid fa-check text-primary me-2"></i> Nhận thông báo tự động</li>
                </ul>
                <div class="mt-4">
                    <a href="/Account/Register" class="btn btn-medical-primary">Đăng ký ngay</a>
                    <a href="/Account/Login" class="btn btn-link text-primary text-decoration-none">Đăng nhập</a>
                </div>
            </div>
        </div>
        
        <!-- Doctor Area -->
        <div id="doctor-area" class="row align-items-center mt-5 pt-5 border-top reveal-right">
            <div class="col-md-6 mb-4 mb-md-0 pe-lg-5">
                <span class="status-badge text-white mb-3" style="background: var(--medical-secondary);">Dành cho Bác sĩ</span>
                <h2 class="fw-bold mb-4">Trang nghiệp vụ tiêu chuẩn</h2>
                <ul class="list-unstyled d-flex flex-column gap-3 text-muted">
                    <li><i class="fa-solid fa-stethoscope text-success me-2"></i> Xem lịch làm việc & lịch khám trong ngày</li>
                    <li><i class="fa-solid fa-notes-medical text-success me-2"></i> Cập nhật kết quả khám, ghi chú chẩn đoán</li>
                    <li><i class="fa-solid fa-clock-rotate-left text-success me-2"></i> Xem lại lịch sử y án bệnh nhân</li>
                </ul>
                <div class="mt-4">
                    <a href="/Account/Login" class="btn btn-medical-outline text-decoration-none">Đăng nhập Bác sĩ</a>
                </div>
            </div>
            <div class="col-md-6 text-center">
                <div class="p-5 bg-light rounded-4 border page-card">
                    <i class="fa-solid fa-user-doctor text-secondary mb-3" style="font-size: 5rem;"></i>
                    <h4 class="fw-bold">Workpsace Bác Sĩ</h4>
                    <p class="text-muted">Bảo mật & Tối ưu luồng khám chữa bệnh</p>
                </div>
            </div>
        </div>

        <!-- Admin Area -->
        <div id="admin-area" class="row align-items-center mt-5 pt-5 border-top reveal-left">
            <div class="col-md-6 order-2 order-md-1 text-center">
                <div class="p-5 bg-dark rounded-4 text-white page-card">
                    <i class="fa-solid fa-server mb-3" style="font-size: 5rem; color: var(--medical-accent);"></i>
                    <h4 class="fw-bold">Căn hộ Quản trị</h4>
                    <p class="text-light">Bức tranh toàn cảnh về hoạt động y tế</p>
                </div>
            </div>
            <div class="col-md-6 order-1 order-md-2 mb-4 mb-md-0 px-lg-5">
                <span class="status-badge bg-dark text-white mb-3">Dành cho Admin</span>
                <h2 class="fw-bold mb-4">Quản trị dữ liệu tập trung</h2>
                <ul class="list-unstyled d-flex flex-column gap-3 text-muted">
                    <li><i class="fa-solid fa-users text-dark me-2"></i> Quản lý toàn bộ tài khoản y bác sĩ & bệnh nhân</li>
                    <li><i class="fa-solid fa-building text-dark me-2"></i> Quản lý danh mục chuyên khoa, lịch biểu bác sĩ</li>
                    <li><i class="fa-solid fa-chart-line text-dark me-2"></i> Báo cáo thống kê hoạt động bệnh viện</li>
                </ul>
                <div class="mt-4">
                    <a href="/Account/Login" class="btn btn-dark">Vào trang quản trị</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Quick Booking Form -->
<section id="booking" class="page-section quick-booking-section py-5 my-5 reveal">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="glass-card form-card shadow-lg p-md-5">
                    <div class="text-center mb-4">
                        <i class="fa-solid fa-calendar-plus fs-1 text-primary mb-3"></i>
                        <h2 class="fw-bold">Đặt lịch khám nhanh</h2>
                        <p class="text-muted">Vui lòng điền thông tin để chúng tôi liên hệ xác nhận giờ ưu tiên.</p>
                    </div>
                    
                    <form id="quickBookingForm">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Họ và tên</label>
                                <input type="text" class="medical-input" placeholder="Nguyễn Văn A" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Số điện thoại</label>
                                <input type="tel" class="medical-input" placeholder="0909..." required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Chuyên khoa</label>
                                <select class="medical-select" required>
                                    <option value="" disabled selected>Chọn chuyên khoa</option>
                                    <option value="1">Nội tổng quát</option>
                                    <option value="2">Tim mạch</option>
                                    <option value="3">Tai mũi họng</option>
                                    <option value="4">Khác</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Bác sĩ</label>
