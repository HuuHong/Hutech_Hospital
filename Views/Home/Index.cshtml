@{
    ViewData["Title"] = "HUTECH_Hospital - Bệnh viện thông minh";
}

<!-- Hero Section -->
<section id="home" class="hospital-hero page-hero">
    <div class="medical-bg-orbs">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
        <div class="mesh-grid"></div>
    </div>
    
    <div class="container relative z-10">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0 text-center text-lg-start">
                <div class="d-inline-flex align-items-center gap-2 px-3 py-2 rounded-pill bg-white shadow-sm mb-4" style="border: 1px solid var(--medical-soft)">
                    <span class="spinner-grow spinner-grow-sm text-primary" role="status" aria-hidden="true"></span>
                    <span class="font-weight-600 text-primary small">Y Tế Số Thông Minh</span>
                </div>
                
                <h1 class="display-3 fw-bolder mb-4" style="color: var(--medical-dark); letter-spacing: -1px;">
                    HUTECH_Hospital
                </h1>
                <h2 class="h4 text-muted mb-4 fw-normal line-height-base">
                    Nền tảng quản lý bệnh viện và đặt lịch khám thông minh cho HUTECH Khu E
                </h2>
                <p class="lead mb-5 text-secondary">
                    Kết nối bệnh nhân, bác sĩ và hệ thống quản trị trên một nền tảng y tế số hiện đại, nhanh chóng và an toàn.
                </p>
                
                <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center justify-content-lg-start mb-5">
                    <a href="#booking" class="btn btn-medical-primary btn-lg">
                        <i class="fa-regular fa-calendar-check me-2"></i> Đặt lịch khám ngay
                    </a>
                    <a href="#doctors" class="btn btn-medical-outline btn-lg">
                        <i class="fa-solid fa-user-doctor me-2"></i> Tìm bác sĩ
                    </a>
                </div>
                
                <div class="row g-3">
                    <div class="col-sm-6 col-md-3">
                        <div class="stat-card p-3 d-flex flex-column align-items-center text-center">
                            <h3 class="fs-4 text-primary fw-bold mb-1">120+</h3>
                            <span class="small text-muted">Bác sĩ</span>
                        </div>
                    </div>
                    <div class="col-sm-6 col-md-3">
                        <div class="stat-card p-3 d-flex flex-column align-items-center text-center">
                            <h3 class="fs-4 text-primary fw-bold mb-1">8.000+</h3>
                            <span class="small text-muted">Bệnh nhân</span>
                        </div>
                    </div>
                    <div class="col-sm-6 col-md-3">
                        <div class="stat-card p-3 d-flex flex-column align-items-center text-center">
                            <h3 class="fs-4 text-primary fw-bold mb-1">18+</h3>
                            <span class="small text-muted">Chuyên khoa</span>
                        </div>
                    </div>
                    <div class="col-sm-6 col-md-3">
                        <div class="stat-card p-3 d-flex flex-column align-items-center text-center">
                            <h3 class="fs-4 text-primary fw-bold mb-1">98%</h3>
                            <span class="small text-muted">Hài lòng</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-6 position-relative hero-doctor-img d-none d-lg-block">
                <!-- Medical Technology Element: ECG Line -->
                <div class="position-absolute top-50 start-0 w-100 bg-white rounded p-3 shadow" style="transform: translateY(-50%); z-index: 5;">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="small fw-bold text-muted">Hệ thống giám sát nhịp tim (Mô phỏng)</span>
                        <span class="small fw-bold text-success"><i class="fa-solid fa-heart-pulse"></i> Hoạt động tốt</span>
                    </div>
                    <div class="ecg-line"></div>
                </div>
                <!-- Có thể thay bằng thẻ img mượn từ url nếu muốn -->
                <div class="doctor-placeholder shadow-lg border border-4 border-white"></div>
            </div>
        </div>
    </div>
</section>

<!-- About Section -->
<section id="about" class="page-section py-5 bg-white reveal">
    <div class="container">
        <div class="row align-items-center mb-5">
            <div class="col-lg-5 mb-4 mb-lg-0">
                <span class="text-primary fw-bold text-uppercase tracking-wide small mb-2 d-block">Về Chúng Tôi</span>
                <h2 class="section-title mb-4">Quản lý bệnh viện thông minh thế hệ mới</h2>
                <p class="text-muted">
                    HUTECH_Hospital áp dụng công nghệ số vào y tế, giúp đơn giản hóa quy trình đặt lịch, lưu trữ hồ sơ bệnh án điện tử an toàn. Tự động hóa các thao tác cho bệnh nhân lẫn bác sĩ.
                </p>
                <a href="#departments" class="btn btn-medical-outline mt-3">Tìm hiểu dịch vụ</a>
            </div>
            <div class="col-lg-6 offset-lg-1">
                <div class="row g-4">
                    <div class="col-sm-6 text-center">
                        <div class="p-4 bg-light rounded-4 page-card shadow-sm h-100 reveal-up">
                            <div class="fs-1 text-primary mb-3"><i class="fa-solid fa-notes-medical"></i></div>
                            <h5 class="fw-bold">Hồ sơ điện tử</h5>
                            <p class="text-muted small">Cập nhật nhanh, đồng bộ với nền tảng y tế số.</p>
                        </div>
                    </div>
                    <div class="col-sm-6 text-center">
                        <div class="p-4 bg-light rounded-4 page-card shadow-sm h-100 reveal-up" style="transition-delay: 0.1s">
                            <div class="fs-1 text-primary mb-3"><i class="fa-solid fa-bell"></i></div>
                            <h5 class="fw-bold">Thông báo tự động</h5>
                            <p class="text-muted small">Nhắc hẹn kịp thời qua email hoặc tin nhắn.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Departments Section -->
<section id="departments" class="page-section py-5 reveal">
