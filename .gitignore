# Web workbench (sass)
.sass-cache/

# NuGet Packages
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/

# SQL Server files
*.mdf
*.ldf
*.ndf

# Local History for Visual Studio
**/.localhistory/
.vshistory/

# Windows Installer files from build outputs
*.cab
*.msi
