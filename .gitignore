# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.VisualState.xml
TestResult.xml
nunit-*.xml
*.received.*

# ASP.NET Core
project.lock.json
project.fragment.lock.json
artifacts/
.artifacts/
ScaffoldingReadMe.txt

# StyleCop
StyleCopReport.xml

